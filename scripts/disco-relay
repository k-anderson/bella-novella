#!/usr/bin/env bash
set -euo pipefail

# Disco relay control for Waveshare 3-relay HAT.
#
# Wiring assumption:
#   K1 COM -> actuator terminal A
#   K1 NC  -> 0V
#   K1 NO  -> +V
#
#   K2 COM -> actuator terminal B
#   K2 NC  -> 0V
#   K2 NO  -> +V
#
# Therefore:
#   motor stop/default: K1 OFF, K2 OFF = A 0V, B 0V
#   motor up/extend:    K1 ON,  K2 OFF = A +V, B 0V
#   motor down/retract: K1 OFF, K2 ON  = A 0V, B +V
#
# Spot lights (Relay 3 / K3):
#   raise <seconds> [percent]:
#     Spot lights turn ON after <percent>% of the raise time and stay ON.
#
#   lower <seconds> [percent]:
#     Spot lights start ON and turn OFF after <percent>% of the lower time,
#     staying OFF when the movement finishes.
#
# Waveshare relay HAT mapping:
#   K1 / Relay 1: P25 / BCM 26 / physical pin 37
#   K2 / Relay 2: P28 / BCM 20 / physical pin 38
#   K3 / Relay 3: P29 / BCM 21 / physical pin 40
#
# Waveshare relay input behavior:
#   GPIO LOW  = relay ON / energized
#   GPIO HIGH = relay OFF / de-energized

K1_GPIO=26
K2_GPIO=20
K3_GPIO=21

LOCK_FILE="/run/disco-relay.lock"
PID_FILE="/run/disco-relay.pid"
# Tracks whether the ball is up or down. It lives on /run (tmpfs), so it resets
# each boot. When there is no state (fresh boot, or after brake) the position
# reads "unknown" so that EITHER raise (911) or lower (811) will run next.
STATE_FILE="/run/disco-relay.state"
LOG_TAG="disco-relay"
SETTLE_TIME="0.15"

SPOT_LIGHTS_ON_AFTER_PERCENT_DEFAULT=50
SPOT_LIGHTS_OFF_AFTER_PERCENT_DEFAULT=50

usage() {
  cat <<USAGE
Usage:
  disco-relay raise <seconds> [spot_lights_on_after_percent]
  disco-relay lower <seconds> [spot_lights_off_after_percent]
  disco-relay brake
  disco-relay status
  disco-relay position

Behavior:
  raise:  run the motor up for <seconds>; turn the spot lights ON after the
          given percent of that time; leave the lights ON when finished.
  lower:  run the motor down for <seconds>; turn the spot lights OFF after the
          given percent of that time; leave the lights OFF when finished.
  brake:  immediately stop the motor and cancel any movement in progress. The
          tracked position is reset to "unknown".
  status: print the current relay states, position, and whether a movement is
          running.
  position: print "up", "down", or "unknown" (unknown at boot or after brake).

Concurrency:
  raise/lower take a non-blocking lock and run the movement in the background.
  If a movement is already running the command prints "busy" and makes no
  change; otherwise it prints "started". brake always preempts.

Examples:
  disco-relay raise 10 40
  disco-relay lower 10 60
  disco-relay brake
  disco-relay status
USAGE
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

gpio_set_raw() {
  local gpio="$1"
  local raw="$2"   # dl or dh

  if have_cmd pinctrl; then
    pinctrl set "$gpio" op "$raw"
  elif have_cmd raspi-gpio; then
    raspi-gpio set "$gpio" op "$raw"
  else
    echo "ERROR: neither pinctrl nor raspi-gpio was found." >&2
    exit 1
  fi
}

gpio_get() {
  local gpio="$1"

  if have_cmd pinctrl; then
    pinctrl get "$gpio"
  elif have_cmd raspi-gpio; then
    raspi-gpio get "$gpio"
  else
    echo "ERROR: neither pinctrl nor raspi-gpio was found." >&2
    exit 1
  fi
}

relay_on() {
  # active-low: ON = GPIO low
  gpio_set_raw "$1" dl
}

relay_off() {
  # active-low: OFF = GPIO high
  gpio_set_raw "$1" dh
}

is_number() {
  local value="$1"
  awk -v v="$value" 'BEGIN { exit !(v ~ /^[0-9]+([.][0-9]+)?$/) }'
}

valid_seconds() {
  local value="$1"

  if ! is_number "$value"; then
    echo "ERROR: seconds must be numeric, got '$value'" >&2
    exit 2
  fi

  awk -v v="$value" 'BEGIN { exit !(v > 0) }' || {
    echo "ERROR: seconds must be greater than 0, got '$value'" >&2
    exit 2
  }
}

valid_percent() {
  local name="$1"
  local value="$2"

  if ! is_number "$value"; then
    echo "ERROR: ${name} must be numeric, got '$value'" >&2
    exit 2
  fi

  awk -v v="$value" 'BEGIN { exit !(v >= 0 && v <= 100) }' || {
    echo "ERROR: ${name} must be between 0 and 100, got '$value'" >&2
    exit 2
  }
}

calc() {
  awk "BEGIN { printf \"%.3f\", $* }"
}

motor_stop() {
  relay_off "$K1_GPIO"
  relay_off "$K2_GPIO"

  logger -t "$LOG_TAG" "motor=stop k1=off k2=off actuator_a=0v actuator_b=0v"
  echo "motor=stop actuator_a=0V actuator_b=0V"
}

motor_up() {
  relay_on  "$K1_GPIO"
  relay_off "$K2_GPIO"

  logger -t "$LOG_TAG" "motor=up k1=on k2=off actuator_a=+v actuator_b=0v"
  echo "motor=up actuator_a=+V actuator_b=0V"
}

motor_down() {
  relay_off "$K1_GPIO"
  relay_on  "$K2_GPIO"

  logger -t "$LOG_TAG" "motor=down k1=off k2=on actuator_a=0v actuator_b=+v"
  echo "motor=down actuator_a=0V actuator_b=+V"
}

spot_lights_on() {
  relay_on "$K3_GPIO"
  logger -t "$LOG_TAG" "spot_lights=on"
  echo "spot_lights=on"
}

spot_lights_off() {
  relay_off "$K3_GPIO"
  logger -t "$LOG_TAG" "spot_lights=off"
  echo "spot_lights=off"
}

# Position tracking. No state file (fresh boot or after brake) reads "unknown",
# so either raise or lower will run. A completed raise/lower records up/down.
read_position() {
  if [ -r "$STATE_FILE" ]; then
    cat "$STATE_FILE" 2>/dev/null || printf 'unknown'
  else
    printf 'unknown'
  fi
}

write_position() {
  printf '%s' "$1" >"$STATE_FILE" 2>/dev/null || true
  logger -t "$LOG_TAG" "position=$1"
}

# Sleep that a brake can interrupt. A bare `sleep` defers a trapped TERM/INT
# until it finishes, which would keep the movement — and the lock fd it holds —
# alive after a brake; backgrounding the sleep and `wait`-ing lets the trap run
# at once. The current sleep's pid is tracked so the trap can kill it.
movement_sleep_pid=""
interruptible_sleep() {
  sleep "$1" &
  movement_sleep_pid=$!
  wait "$movement_sleep_pid"
}

# TERM/INT handler for a running movement (brake): stop the motor, kill any
# in-progress sleep so its inherited lock fd is released, drop the pid file, and
# exit. This frees the flock promptly so the next raise/lower can start.
preempt_movement() {
  trap - TERM INT
  [ -n "$movement_sleep_pid" ] && kill "$movement_sleep_pid" 2>/dev/null || true
  motor_stop
  rm -f "$PID_FILE"
  exit 143
}

perform_raise() {
  local seconds="$1"
  local on_after_percent="$2"

  # brake (or any TERM) preempts this movement cleanly; interruptible sleeps let
  # the trap fire at once and release the movement lock.
  trap preempt_movement TERM INT
  trap 'rm -f "$PID_FILE"' EXIT

  local lights_on_at before_lights_on after_lights_on
  lights_on_at="$(calc "$seconds * $on_after_percent / 100")"
  before_lights_on="$lights_on_at"
  after_lights_on="$(calc "$seconds - $lights_on_at")"

  logger -t "$LOG_TAG" "perform=raise seconds=${seconds} spot_lights_on_after_percent=${on_after_percent} spot_lights_on_at=${lights_on_at}s"

  motor_stop
  interruptible_sleep "$SETTLE_TIME"

  motor_up

  interruptible_sleep "$before_lights_on"
  spot_lights_on

  interruptible_sleep "$after_lights_on"

  motor_stop
  spot_lights_on

  write_position up
}

perform_lower() {
  local seconds="$1"
  local off_after_percent="$2"

  # brake (or any TERM) preempts this movement cleanly; interruptible sleeps let
  # the trap fire at once and release the movement lock.
  trap preempt_movement TERM INT
  trap 'rm -f "$PID_FILE"' EXIT

  local lights_off_at before_lights_off after_lights_off
  lights_off_at="$(calc "$seconds * $off_after_percent / 100")"
  before_lights_off="$lights_off_at"
  after_lights_off="$(calc "$seconds - $lights_off_at")"

  logger -t "$LOG_TAG" "perform=lower seconds=${seconds} spot_lights_off_after_percent=${off_after_percent} spot_lights_off_at=${lights_off_at}s"

  # Spot lights start ON, then turn OFF after the configured percentage.
  spot_lights_on

  motor_stop
  interruptible_sleep "$SETTLE_TIME"

  motor_down

  interruptible_sleep "$before_lights_off"
  spot_lights_off

  interruptible_sleep "$after_lights_off"

  motor_stop
  spot_lights_off

  write_position down
}

start_move() {
  local direction="$1"
  local seconds="${2:-}"
  local percent="${3:-}"

  if [ -z "$seconds" ]; then
    echo "ERROR: ${direction} requires seconds" >&2
    usage >&2
    exit 2
  fi
  valid_seconds "$seconds"

  if [ "$direction" = "up" ]; then
    percent="${percent:-$SPOT_LIGHTS_ON_AFTER_PERCENT_DEFAULT}"
    valid_percent "spot_lights_on_after_percent" "$percent"
  else
    percent="${percent:-$SPOT_LIGHTS_OFF_AFTER_PERCENT_DEFAULT}"
    valid_percent "spot_lights_off_after_percent" "$percent"
  fi

  mkdir -p "$(dirname "$LOCK_FILE")"

  # Non-blocking lock: if a movement is already running, reject immediately so
  # the dialplan can tell the caller instead of queueing another movement.
  exec 9>"$LOCK_FILE"
  if ! flock -n 9; then
    logger -t "$LOG_TAG" "rejected reason=busy direction=${direction}"
    printf 'busy'
    return 0
  fi

  # Run the movement in the background so the caller (FreeSWITCH) returns at
  # once. The child inherits fd 9 and therefore holds the lock for the whole
  # movement; its output is detached so the caller sees EOF immediately.
  if [ "$direction" = "up" ]; then
    perform_raise "$seconds" "$percent" >/dev/null 2>&1 </dev/null &
  else
    perform_lower "$seconds" "$percent" >/dev/null 2>&1 </dev/null &
  fi
  echo "$!" >"$PID_FILE" 2>/dev/null || true

  logger -t "$LOG_TAG" "started direction=${direction} seconds=${seconds} percent=${percent} pid=$!"
  printf 'started'
}

run_stop() {
  # brake preempts any in-progress movement, then forces the motor off.
  if [ -f "$PID_FILE" ]; then
    local pid
    pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    if [ -n "${pid}" ] && kill -0 "$pid" 2>/dev/null; then
      kill -TERM "$pid" 2>/dev/null || true
      for _ in 1 2 3 4 5; do
        kill -0 "$pid" 2>/dev/null || break
        sleep 0.1
      done
    fi
    rm -f "$PID_FILE"
  fi

  motor_stop
  # Position is now indeterminate; reset to "unknown" so raise or lower will run.
  rm -f "$STATE_FILE"
  logger -t "$LOG_TAG" "cmd=brake state=stopped position=unknown"
}

show_status() {
  echo "K1 / Relay 1 / GPIO ${K1_GPIO} (motor A): $(gpio_get "$K1_GPIO")"
  echo "K2 / Relay 2 / GPIO ${K2_GPIO} (motor B): $(gpio_get "$K2_GPIO")"
  echo "K3 / Relay 3 / GPIO ${K3_GPIO} (spot lights): $(gpio_get "$K3_GPIO")"
  echo
  echo "Logical states:"
  echo "  Relay ON  = GPIO low"
  echo "  Relay OFF = GPIO high"
  echo
  echo "  motor stop = K1 OFF, K2 OFF = A 0V, B 0V"
  echo "  motor up   = K1 ON,  K2 OFF = A +V, B 0V"
  echo "  motor down = K1 OFF, K2 ON  = A 0V, B +V"
  echo
  echo "Spot-light timing defaults:"
  echo "  raise: lights ON after ${SPOT_LIGHTS_ON_AFTER_PERCENT_DEFAULT}% of raise time"
  echo "  lower: lights OFF after ${SPOT_LIGHTS_OFF_AFTER_PERCENT_DEFAULT}% of lower time"
  echo
  echo "Position: $(read_position) (unknown at boot or after brake)"
  echo
  if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null; then
    echo "Movement: IN PROGRESS (pid $(cat "$PID_FILE"))"
  else
    echo "Movement: idle"
  fi
}

main() {
  local cmd="${1:-}"

  case "$cmd" in
    raise)
      shift
      start_move up "$@"
      ;;

    lower)
      shift
      start_move down "$@"
      ;;

    brake)
      run_stop
      ;;

    position)
      read_position
      ;;

    status)
      show_status
      ;;

    -h|--help|help|'')
      usage
      ;;

    *)
      echo "ERROR: unknown command '$cmd'" >&2
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
