#!/usr/bin/env bash
set -euo pipefail

# Message store for the Bella Novella IVR.
#
# Recordings live in MESSAGES_DIR as msg_<timestamp>_<uuid>.wav so a lexical
# sort equals the order received. Recordings are NEVER deleted during normal
# operation. The IVR only plays the newest PLAYBACK_LIMIT messages; older ones
# are KEPT on disk and are pruned (the minimum number of oldest, and never the
# newest PLAYBACK_LIMIT) only when free space drops below MIN_FREE_MB.
#
# It runs as the freeswitch user (recordings/ is freeswitch-owned), so no sudo
# is needed. All output is newline-free so it can be used directly in the
# FreeSWITCH dialplan via ${system(...)}.
#
# Commands:
#   rotate                  reclaim disk space ONLY when free space is low: first
#                           prune archived recordings (oldest-first; the dated
#                           archive folders themselves are kept), then, if still
#                           low, the oldest live messages beyond the newest
#                           PLAYBACK_LIMIT
#   archive                 move every live recording into a new dated subfolder
#                           (archived-<UTCstamp>-XXXX/) so count/count-all read an
#                           empty store; print how many were moved. Reversible
#                           (move the files back). Archived recordings stay on
#                           disk until `rotate` needs the space.
#   count                   print how many messages are playable (<= PLAYBACK_LIMIT)
#   resolve <index>         print the absolute path of the 1-based Nth playable message
#   announcement <index>    print a lead-in announcement wav for the Nth message,
#                           dealt from the playback-announcement-<index>-* shuffle
#                           bag, or empty when no such variant exists
#   step <index> next|prev  print the next/previous clamped index (0 = past end)
#   count-all               print the total number of stored messages (unwindowed)
#   resolve-all <index>     like resolve, but over ALL stored messages, newest-first
#   step-all <index> next|prev  like step, but clamped to the full archive
#   delete-all <index>      delete the Nth full-archive message (newest-first); the
#                           store re-lists on every call so the remaining indices
#                           renumber at once, as if it had never been stored
#   drawer-start            print the 1-based full-archive index just past the
#                           playback window (PLAYBACK_LIMIT+1), or 0 when the
#                           archive does not exceed the window
#   pick <prefix>           print the absolute path of the next
#                           prompts/<prefix>-N.wav (e.g. invalid-entry,
#                           main-menu-short-variant, playback-announcement-3,
#                           game-win) from a per-prefix shuffle-bag: every
#                           variant plays once, in random
#                           order, before any repeats. State lives on tmpfs
#                           (BELLA_PICK_STATE_DIR, default /run/bella-novella/
#                           pick); falls back to a plain random draw if that dir
#                           is unusable. Empty when no such files exist.

MESSAGES_DIR="${BELLA_MESSAGES_DIR:-/usr/local/freeswitch/recordings/messages}"
PLAYBACK_LIMIT="${BELLA_PLAYBACK_LIMIT:-10}"
# Old messages are pruned only when free space on the messages filesystem drops
# below this many megabytes.
MIN_FREE_MB="${BELLA_MIN_FREE_MB:-200}"

# Custom prompts directory (absolute path, played directly by FreeSWITCH).
PROMPTS_DIR="${BELLA_PROMPTS_DIR:-/usr/local/freeswitch/prompts}"

# State directory for the no-repeat "pick" shuffle-bags. On tmpfs so it adds no
# SD-card wear and resets on boot; created (owned by the freeswitch user) via
# RuntimeDirectory=bella-novella in the systemd unit. If it can't be used, pick
# falls back to an independent random draw so the IVR never breaks.
PICK_STATE_DIR="${BELLA_PICK_STATE_DIR:-/run/bella-novella/pick}"

# Sorted oldest-first (lexical == chronological because of the name prefix).
list_messages() {
  find "$MESSAGES_DIR" -maxdepth 1 -type f -name 'msg_*.wav' 2>/dev/null | sort
}

# The playable window: the newest PLAYBACK_LIMIT messages, newest-first (so the
# IVR plays newest to oldest; index 1 == newest).
playback_list() {
  list_messages | tail -n "$PLAYBACK_LIMIT" | tac
}

# The full archive, newest-first (index 1 == newest). Unlike playback_list this
# is NOT capped at PLAYBACK_LIMIT; it backs the "dial 9 to keep going" extended
# playback that continues past the curated window into every stored message.
full_list() {
  list_messages | tac
}

# Archived recordings (moved out of the live store by `archive`) live one level
# down, inside dated archived-* subfolders, so the maxdepth-1 listing above never
# sees them. This lists them oldest-first by their embedded msg_<timestamp>,
# across every archive folder, for space reclamation by `rotate`.
list_archived() {
  find "$MESSAGES_DIR" -mindepth 2 -type f -name 'msg_*.wav' -printf '%f\t%p\n' 2>/dev/null \
    | sort | cut -f2-
}

# True when free space on the messages filesystem is below MIN_FREE_MB.
disk_low() {
  local free_mb
  free_mb="$(df -Pm "$MESSAGES_DIR" 2>/dev/null | awk 'NR==2 {print $4}')"
  [ -n "${free_mb:-}" ] || return 1
  [ "$free_mb" -lt "$MIN_FREE_MB" ]
}

cmd_rotate() {
  mkdir -p "$MESSAGES_DIR"

  # Recordings are NEVER deleted during normal operation. Only when free space
  # is low do we reclaim the minimum needed to bring free space back above
  # MIN_FREE_MB. No-speech / empty recordings are discarded at record time by
  # the dialplan (record_min_sec).

  # 1) Reclaim from the ARCHIVE first. Recordings moved aside by `archive` were
  #    intentionally cleared from the live store, so they are the expendable
  #    space: prune them oldest-first. Only the recordings are removed -- the
  #    dated archive folders are left in place.
  local arch
  while disk_low; do
    arch="$(list_archived | head -n 1)"
    [ -n "$arch" ] || break
    rm -f "$arch"
  done

  # 2) Still low? Fall back to the oldest LIVE messages, never touching the
  #    newest PLAYBACK_LIMIT (the messages the IVR can still play back).
  local oldest count
  while disk_low; do
    count="$(list_messages | grep -c . || true)"
    [ "${count:-0}" -gt "$PLAYBACK_LIMIT" ] || break
    oldest="$(list_messages | head -n 1)"
    [ -n "$oldest" ] || break
    rm -f "$oldest"
  done
}

# Move every live recording into a new dated subfolder of MESSAGES_DIR
# (archived-<UTCstamp>-XXXX/). Because list_messages only looks one level deep
# (maxdepth 1, -type f), the moved recordings vanish from count AND count-all, so
# the IVR behaves as if the store were empty -- without deleting anything. The
# recordings sit in the archive until `rotate` needs the space (see above).
# Prints the number of recordings moved (0 when the store was already empty).
cmd_archive() {
  mkdir -p "$MESSAGES_DIR"
  local files
  mapfile -t files < <(list_messages)
  local n="${#files[@]}"
  if [ "$n" -eq 0 ]; then printf '0'; return 0; fi

  local dest
  dest="$(mktemp -d "$MESSAGES_DIR/archived-$(date -u +%Y%m%d-%H%M%S)-XXXX" 2>/dev/null)" \
    || { printf '0'; return 0; }

  local f moved=0
  for f in "${files[@]}"; do
    if mv -f "$f" "$dest/" 2>/dev/null; then moved=$(( moved + 1 )); fi
  done
  printf '%s' "$moved"
}

cmd_count() {
  local n
  n="$(playback_list | grep -c . || true)"
  printf '%s' "${n:-0}"
}

cmd_resolve() {
  local idx="${1:-0}"
  case "$idx" in
    ''|*[!0-9]*) printf ''; return 0 ;;
  esac
  [ "$idx" -ge 1 ] || { printf ''; return 0; }

  local files n
  mapfile -t files < <(playback_list)
  n="${#files[@]}"
  if [ "$idx" -gt "$n" ]; then printf ''; return 0; fi
  printf '%s' "${files[$(( idx - 1 ))]}"
}

# Print the lead-in announcement wav for the 1-based Nth message, played as a
# separate prompt before the message. Each message index has up to three
# interchangeable variants (playback-announcement-<idx>-1..3); deal one from the
# per-index shuffle bag (via cmd_pick) so the same lead-in rarely repeats back to
# back. Empty when no variant exists for that index (so the message plays with no
# announcement).
cmd_announcement() {
  local idx="${1:-0}"
  case "$idx" in
    ''|*[!0-9]*) printf ''; return 0 ;;
  esac
  [ "$idx" -ge 1 ] || { printf ''; return 0; }
  cmd_pick "playback-announcement-${idx}"
}

cmd_step() {
  local idx="${1:-0}" dir="${2:-next}" n
  case "$idx" in
    ''|*[!0-9]*) idx=0 ;;
  esac
  n="$(cmd_count)"
  case "$dir" in
    next) if [ "$idx" -lt "$n" ]; then printf '%s' "$(( idx + 1 ))"; else printf '0'; fi ;;
    prev) if [ "$idx" -gt 1 ]; then printf '%s' "$(( idx - 1 ))"; else printf '1'; fi ;;
    *)    printf '0' ;;
  esac
}

# Total number of stored messages (the entire archive, not just the window).
cmd_count_all() {
  local n
  n="$(list_messages | grep -c . || true)"
  printf '%s' "${n:-0}"
}

# Like cmd_resolve, but the 1-based index is into the FULL archive newest-first,
# so extended playback can reach messages older than the curated window.
cmd_resolve_all() {
  local idx="${1:-0}"
  case "$idx" in
    ''|*[!0-9]*) printf ''; return 0 ;;
  esac
  [ "$idx" -ge 1 ] || { printf ''; return 0; }

  local files n
  mapfile -t files < <(full_list)
  n="${#files[@]}"
  if [ "$idx" -gt "$n" ]; then printf ''; return 0; fi
  printf '%s' "${files[$(( idx - 1 ))]}"
}

# Like cmd_step, but clamped to the full archive (0 = stepped past the oldest).
cmd_step_all() {
  local idx="${1:-0}" dir="${2:-next}" n
  case "$idx" in
    ''|*[!0-9]*) idx=0 ;;
  esac
  n="$(cmd_count_all)"
  case "$dir" in
    next) if [ "$idx" -lt "$n" ]; then printf '%s' "$(( idx + 1 ))"; else printf '0'; fi ;;
    prev) if [ "$idx" -gt 1 ]; then printf '%s' "$(( idx - 1 ))"; else printf '1'; fi ;;
    *)    printf '0' ;;
  esac
}

# Delete the Nth full-archive message (1-based, newest-first). Reuses cmd_resolve_all
# so only an existing msg_*.wav inside MESSAGES_DIR can ever be removed. Because the
# helpers re-list the directory on every call, the remaining indices renumber
# immediately, as if the deleted message had never been stored. Newline-free.
cmd_delete_all() {
  local idx="${1:-0}" file
  file="$(cmd_resolve_all "$idx")"
  [ -n "$file" ] || { printf ''; return 0; }
  rm -f "$file"
  printf ''
}

# The full-archive index just past the curated playback window: PLAYBACK_LIMIT+1
# when the archive holds more than the window, else 0 (nothing more to play).
cmd_drawer_start() {
  local total
  total="$(list_messages | grep -c . || true)"
  if [ "${total:-0}" -gt "$PLAYBACK_LIMIT" ]; then
    printf '%s' "$(( PLAYBACK_LIMIT + 1 ))"
  else
    printf '0'
  fi
}

# Print the absolute path of a $PROMPTS_DIR/<prefix>-N.wav. Instead of an
# independent random draw each call (which can repeat the same variant back to
# back), this deals from a per-prefix "shuffle bag": every variant is played
# once, in a random order, before any repeats. State persists between
# invocations in PICK_STATE_DIR (tmpfs) and is guarded by flock so concurrent
# calls get distinct entries. Backs every interchangeable prompt family the IVR
# chooses at random: the invalid-entry scolds, the short main-menu greetings, the
# per-message playback announcements, and the game intro/win/lose and higher/lower
# variants. Falls back to a single
# random draw if the state dir is unusable, so the IVR never breaks.
cmd_pick() {
  local prefix="${1:-}"
  [ -n "$prefix" ] || { printf ''; return 0; }
  shopt -s nullglob
  local files=( "$PROMPTS_DIR/$prefix"-*.wav )
  local n="${#files[@]}"
  [ "$n" -gt 0 ] || { printf ''; return 0; }
  if [ "$n" -eq 1 ]; then printf '%s' "${files[0]}"; return 0; fi

  local pick
  if pick="$(pick_from_bag "$prefix" "${files[@]}")" && [ -n "$pick" ]; then
    printf '%s' "$pick"
  else
    printf '%s' "${files[$(( RANDOM % n ))]}"
  fi
}

# Deal the next entry from the per-prefix shuffle bag under an flock. Reshuffles
# the current variant set whenever the bag is empty or stale (variants added or
# removed), and avoids repeating the last-played entry across a refill. Prints
# the chosen path, or returns non-zero if the state dir can't be used (the
# caller then falls back to a random draw).
pick_from_bag() {
  local prefix="$1"; shift
  local files=( "$@" )

  mkdir -p "$PICK_STATE_DIR" 2>/dev/null || return 1
  [ -w "$PICK_STATE_DIR" ] || return 1

  local bag="$PICK_STATE_DIR/$prefix.bag"
  local lock="$PICK_STATE_DIR/$prefix.lock"
  local lastf="$PICK_STATE_DIR/$prefix.last"

  local lockfd
  exec {lockfd}>"$lock" 2>/dev/null || return 1
  if ! flock "$lockfd" 2>/dev/null; then
    exec {lockfd}>&- 2>/dev/null || true
    return 1
  fi

  # Keep only bag entries that still exist in the current variant set (drops any
  # variants removed since the bag was built); preserves the shuffled order.
  local remaining=""
  if [ -s "$bag" ]; then
    remaining="$(grep -Fxf <(printf '%s\n' "${files[@]}") "$bag" 2>/dev/null || true)"
  fi

  # Empty or fully stale -> reshuffle the whole current set, then nudge the
  # first entry back if it would immediately repeat the last-played one.
  if [ -z "$remaining" ]; then
    if ! remaining="$(printf '%s\n' "${files[@]}" | shuf 2>/dev/null)"; then
      exec {lockfd}>&- 2>/dev/null || true
      return 1
    fi
    local last=""
    [ -s "$lastf" ] && last="$(cat "$lastf" 2>/dev/null || true)"
    local first="${remaining%%$'\n'*}"
    if [ -n "$last" ] && [ "$first" = "$last" ] && [ "$first" != "$remaining" ]; then
      remaining="${remaining#*$'\n'}"$'\n'"$first"
    fi
  fi

  # Pop the first line; persist the rest of the bag and the last-played entry.
  local choice="${remaining%%$'\n'*}"
  local rest="${remaining#*$'\n'}"
  [ "$rest" != "$remaining" ] || rest=""
  printf '%s\n' "$rest" > "$bag" 2>/dev/null || true
  printf '%s' "$choice" > "$lastf" 2>/dev/null || true

  exec {lockfd}>&- 2>/dev/null || true
  [ -n "$choice" ] || return 1
  printf '%s' "$choice"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    rotate)         cmd_rotate ;;
    archive)        cmd_archive ;;
    count)          cmd_count ;;
    resolve)        cmd_resolve "${2:-}" ;;
    announcement)   cmd_announcement "${2:-}" ;;
    step)           cmd_step "${2:-}" "${3:-}" ;;
    count-all)      cmd_count_all ;;
    resolve-all)    cmd_resolve_all "${2:-}" ;;
    step-all)       cmd_step_all "${2:-}" "${3:-}" ;;
    delete-all)     cmd_delete_all "${2:-}" ;;
    drawer-start)   cmd_drawer_start ;;
    pick)           cmd_pick "${2:-}" ;;
    *)
      echo "usage: bella-messages {rotate|archive|count|resolve <index>|announcement <index>|step <index> next|prev|count-all|resolve-all <index>|step-all <index> next|prev|delete-all <index>|drawer-start|pick <prefix>}" >&2
      exit 2
      ;;
  esac
}

main "$@"
