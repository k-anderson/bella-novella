#!/usr/bin/env bash
set -euo pipefail

# Message store for the Bella Novella IVR.
#
# Recordings live in MESSAGES_DIR as msg_<timestamp>_<uuid>.wav so a lexical
# sort equals the order received. Recordings are NEVER deleted during normal
# operation. The IVR only plays the newest PLAYBACK_LIMIT messages; older ones
# are KEPT on disk and are pruned (the minimum number of oldest, and never the
# newest PLAYBACK_LIMIT) only when free space drops below MIN_FREE_MB.
#
# It runs as the freeswitch user (recordings/ is freeswitch-owned), so no sudo
# is needed. All output is newline-free so it can be used directly in the
# FreeSWITCH dialplan via ${system(...)}.
#
# Commands:
#   rotate                  prune the oldest messages ONLY when disk space is low
#   count                   print how many messages are playable (<= PLAYBACK_LIMIT)
#   resolve <index>         print the absolute path of the 1-based Nth playable message
#   announcement <index>    print the lead-in announcement wav for the Nth message,
#                           or empty when prompts/playback-announcement-<index>.wav
#                           does not exist
#   step <index> next|prev  print the next/previous clamped index (0 = past end)
#   count-all               print the total number of stored messages (unwindowed)
#   resolve-all <index>     like resolve, but over ALL stored messages, newest-first
#   step-all <index> next|prev  like step, but clamped to the full archive
#   ext-start               print the 1-based full-archive index just past the
#                           playback window (PLAYBACK_LIMIT+1), or 0 when the
#                           archive does not exceed the window
#   invalid-prompt          print a random "invalid entry" prompt (relative path)
#   short-menu-prompt       print a random short main-menu greeting (absolute path)

MESSAGES_DIR="${BELLA_MESSAGES_DIR:-/usr/local/freeswitch/recordings/messages}"
PLAYBACK_LIMIT="${BELLA_PLAYBACK_LIMIT:-10}"
# Old messages are pruned only when free space on the messages filesystem drops
# below this many megabytes.
MIN_FREE_MB="${BELLA_MIN_FREE_MB:-200}"

# Custom prompts directory (absolute path, played directly by FreeSWITCH).
PROMPTS_DIR="${BELLA_PROMPTS_DIR:-/usr/local/freeswitch/prompts}"

INVALID_PROMPTS=(
  "$PROMPTS_DIR/invalid-entry-1.wav"
  "$PROMPTS_DIR/invalid-entry-2.wav"
  "$PROMPTS_DIR/invalid-entry-3.wav"
  "$PROMPTS_DIR/invalid-entry-4.wav"
  "$PROMPTS_DIR/invalid-entry-5.wav"
  "$PROMPTS_DIR/invalid-entry-6.wav"
  "$PROMPTS_DIR/invalid-entry-7.wav"
  "$PROMPTS_DIR/invalid-entry-8.wav"
  "$PROMPTS_DIR/invalid-entry-9.wav"
  "$PROMPTS_DIR/invalid-entry-10.wav"
)

# Variants of the short main-menu greeting; one is picked at random each time the
# caller returns to the menu.
SHORT_MENU_PROMPTS=(
  "$PROMPTS_DIR/main-menu-short-variant-1.wav"
  "$PROMPTS_DIR/main-menu-short-variant-2.wav"
  "$PROMPTS_DIR/main-menu-short-variant-3.wav"
  "$PROMPTS_DIR/main-menu-short-variant-4.wav"
  "$PROMPTS_DIR/main-menu-short-variant-5.wav"
  "$PROMPTS_DIR/main-menu-short-variant-6.wav"
  "$PROMPTS_DIR/main-menu-short-variant-7.wav"
  "$PROMPTS_DIR/main-menu-short-variant-8.wav"
  "$PROMPTS_DIR/main-menu-short-variant-9.wav"
)

# Sorted oldest-first (lexical == chronological because of the name prefix).
list_messages() {
  find "$MESSAGES_DIR" -maxdepth 1 -type f -name 'msg_*.wav' 2>/dev/null | sort
}

# The playable window: the newest PLAYBACK_LIMIT messages, newest-first (so the
# IVR plays newest to oldest; index 1 == newest).
playback_list() {
  list_messages | tail -n "$PLAYBACK_LIMIT" | tac
}

# The full archive, newest-first (index 1 == newest). Unlike playback_list this
# is NOT capped at PLAYBACK_LIMIT; it backs the "dial 9 to keep going" extended
# playback that continues past the curated window into every stored message.
full_list() {
  list_messages | tac
}

# True when free space on the messages filesystem is below MIN_FREE_MB.
disk_low() {
  local free_mb
  free_mb="$(df -Pm "$MESSAGES_DIR" 2>/dev/null | awk 'NR==2 {print $4}')"
  [ -n "${free_mb:-}" ] || return 1
  [ "$free_mb" -lt "$MIN_FREE_MB" ]
}

cmd_rotate() {
  mkdir -p "$MESSAGES_DIR"

  # Recordings are NEVER deleted during normal operation. Only when free space
  # is low do we delete the minimum number of OLDEST messages needed to bring
  # free space back above MIN_FREE_MB, and we never delete the newest
  # PLAYBACK_LIMIT (the messages the IVR can still play back). No-speech / empty
  # recordings are discarded at record time by the dialplan (record_min_sec).
  local oldest count
  while disk_low; do
    count="$(list_messages | grep -c . || true)"
    [ "${count:-0}" -gt "$PLAYBACK_LIMIT" ] || break
    oldest="$(list_messages | head -n 1)"
    [ -n "$oldest" ] || break
    rm -f "$oldest"
  done
}

cmd_count() {
  local n
  n="$(playback_list | grep -c . || true)"
  printf '%s' "${n:-0}"
}

cmd_resolve() {
  local idx="${1:-0}"
  case "$idx" in
    ''|*[!0-9]*) printf ''; return 0 ;;
  esac
  [ "$idx" -ge 1 ] || { printf ''; return 0; }

  local files n
  mapfile -t files < <(playback_list)
  n="${#files[@]}"
  if [ "$idx" -gt "$n" ]; then printf ''; return 0; fi
  printf '%s' "${files[$(( idx - 1 ))]}"
}

# Print the lead-in announcement wav for the 1-based Nth message, played as a
# separate prompt before the message. Empty when that announcement file does not
# exist (so the message plays with no announcement).
cmd_announcement() {
  local idx="${1:-0}" ann
  ann="$PROMPTS_DIR/playback-announcement-${idx}.wav"
  if [ -f "$ann" ]; then
    printf '%s' "$ann"
  else
    printf ''
  fi
}

cmd_step() {
  local idx="${1:-0}" dir="${2:-next}" n
  case "$idx" in
    ''|*[!0-9]*) idx=0 ;;
  esac
  n="$(cmd_count)"
  case "$dir" in
    next) if [ "$idx" -lt "$n" ]; then printf '%s' "$(( idx + 1 ))"; else printf '0'; fi ;;
    prev) if [ "$idx" -gt 1 ]; then printf '%s' "$(( idx - 1 ))"; else printf '1'; fi ;;
    *)    printf '0' ;;
  esac
}

# Total number of stored messages (the entire archive, not just the window).
cmd_count_all() {
  local n
  n="$(list_messages | grep -c . || true)"
  printf '%s' "${n:-0}"
}

# Like cmd_resolve, but the 1-based index is into the FULL archive newest-first,
# so extended playback can reach messages older than the curated window.
cmd_resolve_all() {
  local idx="${1:-0}"
  case "$idx" in
    ''|*[!0-9]*) printf ''; return 0 ;;
  esac
  [ "$idx" -ge 1 ] || { printf ''; return 0; }

  local files n
  mapfile -t files < <(full_list)
  n="${#files[@]}"
  if [ "$idx" -gt "$n" ]; then printf ''; return 0; fi
  printf '%s' "${files[$(( idx - 1 ))]}"
}

# Like cmd_step, but clamped to the full archive (0 = stepped past the oldest).
cmd_step_all() {
  local idx="${1:-0}" dir="${2:-next}" n
  case "$idx" in
    ''|*[!0-9]*) idx=0 ;;
  esac
  n="$(cmd_count_all)"
  case "$dir" in
    next) if [ "$idx" -lt "$n" ]; then printf '%s' "$(( idx + 1 ))"; else printf '0'; fi ;;
    prev) if [ "$idx" -gt 1 ]; then printf '%s' "$(( idx - 1 ))"; else printf '1'; fi ;;
    *)    printf '0' ;;
  esac
}

# The full-archive index just past the curated playback window: PLAYBACK_LIMIT+1
# when the archive holds more than the window, else 0 (nothing more to play).
cmd_ext_start() {
  local total
  total="$(list_messages | grep -c . || true)"
  if [ "${total:-0}" -gt "$PLAYBACK_LIMIT" ]; then
    printf '%s' "$(( PLAYBACK_LIMIT + 1 ))"
  else
    printf '0'
  fi
}

cmd_invalid_prompt() {
  printf '%s' "${INVALID_PROMPTS[$(( RANDOM % ${#INVALID_PROMPTS[@]} ))]}"
}

cmd_short_menu_prompt() {
  printf '%s' "${SHORT_MENU_PROMPTS[$(( RANDOM % ${#SHORT_MENU_PROMPTS[@]} ))]}"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    rotate)         cmd_rotate ;;
    count)          cmd_count ;;
    resolve)        cmd_resolve "${2:-}" ;;
    announcement)   cmd_announcement "${2:-}" ;;
    step)           cmd_step "${2:-}" "${3:-}" ;;
    count-all)      cmd_count_all ;;
    resolve-all)    cmd_resolve_all "${2:-}" ;;
    step-all)       cmd_step_all "${2:-}" "${3:-}" ;;
    ext-start)      cmd_ext_start ;;
    invalid-prompt) cmd_invalid_prompt ;;
    short-menu-prompt) cmd_short_menu_prompt ;;
    *)
      echo "usage: bella-messages {rotate|count|resolve <index>|announcement <index>|step <index> next|prev|count-all|resolve-all <index>|step-all <index> next|prev|ext-start|invalid-prompt|short-menu-prompt}" >&2
      exit 2
      ;;
  esac
}

main "$@"
