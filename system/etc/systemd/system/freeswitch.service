[Unit]
Description=FreeSWITCH
After=NetworkManager.service dnsmasq.service
Wants=dnsmasq.service

[Service]
Type=forking
User=freeswitch
Group=freeswitch
WorkingDirectory=/usr/local/freeswitch

# Keep the SQLite core/registration DBs on tmpfs (RAM) instead of the SD card.
# systemd creates/owns /run/freeswitch-db for the service user and wipes it on
# stop; -db points FreeSWITCH's db_dir at it. This eliminates the "SQLite is
# BUSY" contention caused by slow flash writes (core.db + sofia_reg_ata.db).
RuntimeDirectory=freeswitch-db
RuntimeDirectoryMode=0750

ExecStartPre=/usr/local/bin/freeswitch-wait-eth0 eth0 192.168.50.1 30
ExecStart=/usr/local/freeswitch/bin/freeswitch -ncwait -nonat -db /run/freeswitch-db
ExecReload=/usr/local/freeswitch/bin/fs_cli -x "reloadxml"
ExecStop=/usr/local/freeswitch/bin/fs_cli -x "shutdown elegant"

PIDFile=/usr/local/freeswitch/run/freeswitch.pid
Restart=on-failure
RestartSec=5

LimitNOFILE=500000
LimitNPROC=20000
LimitRTPRIO=89
LimitRTTIME=infinity
Nice=-10

# Must be "no" because FreeSWITCH calls sudo disco-relay from bgsystem.
NoNewPrivileges=no
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
