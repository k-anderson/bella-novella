### 16. Install the FreeSWITCH systemd service

Create `/etc/systemd/system/freeswitch.service`:

```sh
sudo tee /etc/systemd/system/freeswitch.service >/dev/null <<'EOF'
[Unit]
Description=FreeSWITCH
After=NetworkManager.service dnsmasq.service disco-relay-boot.service
Wants=dnsmasq.service disco-relay-boot.service

[Service]
Type=forking
User=freeswitch
Group=freeswitch
WorkingDirectory=/usr/local/freeswitch

ExecStartPre=/usr/local/bin/bella-wait-eth0 eth0 192.168.50.1 30
ExecStart=/usr/local/freeswitch/bin/freeswitch -ncwait -nonat
ExecReload=/usr/local/freeswitch/bin/fs_cli -x "reloadxml"
ExecStop=/usr/local/freeswitch/bin/fs_cli -x "shutdown elegant"

PIDFile=/usr/local/freeswitch/run/freeswitch.pid
Restart=on-failure
RestartSec=5

LimitNOFILE=500000
LimitNPROC=20000
LimitRTPRIO=89
LimitRTTIME=infinity
Nice=-10

# Must be "no" because FreeSWITCH calls sudo disco-relay from bgsystem.
NoNewPrivileges=no
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
EOF
```

Create the Ethernet wait helper:

```sh
sudo tee /usr/local/bin/bella-wait-eth0 >/dev/null <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

IFACE="${1:-eth0}"
IP="${2:-192.168.50.1}"
TIMEOUT="${3:-30}"

for i in $(seq 1 "$TIMEOUT"); do
  if ip -4 addr show dev "$IFACE" | grep -q "${IP}/"; then
    exit 0
  fi
  sleep 1
done

echo "ERROR: ${IFACE} did not get ${IP} within ${TIMEOUT}s" >&2
ip -br addr >&2
exit 1
EOF

sudo chmod 755 /usr/local/bin/bella-wait-eth0
```

Enable and start:

```sh
sudo systemctl daemon-reload
sudo systemctl enable freeswitch
sudo systemctl restart freeswitch
```

Check:

```sh
systemctl status freeswitch --no-pager
fs_cli -x "status"
fs_cli -x "sofia status profile ata"
fs_cli -x "show registrations"
```

