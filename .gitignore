# --- Runtime-generated FreeSWITCH state (regenerated on every boot) ---------
# These are recreated automatically; tracking them just adds churn. The empty
# db/ log/ run/ directories are kept (via .gitkeep) so a Pi redeploy has them.
/db/*.db
/db/*.db.db
/log/*.log
/log/*.fsxml
/run/*.pid

# --- Hand-edit backups (not needed for redeploy) ----------------------------
*.backup.*

# NOTE: bin/ lib/ mod/ include/ (aarch64 binaries), sounds/ (incl. recorded
# greetings), fonts/, htdocs/, certs/, conf/, scripts/ are intentionally
# tracked so this repo can fully redeploy the Raspberry Pi.
