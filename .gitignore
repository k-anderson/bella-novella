# --- Runtime-generated FreeSWITCH state (regenerated on every boot) ---------
# These are recreated automatically; tracking them just adds churn. The empty
# db/ log/ run/ directories are kept (via .gitkeep) so a Pi redeploy has them.
/db/*.db
/db/*.db.db
/log/*.log
/log/*.fsxml
/run/*.pid

# --- Hand-edit backups (not needed for redeploy) ----------------------------
*.backup.*

# --- Python venv for bella-regen-prompts (dev-only, recreated by install.sh) --
/.venv/

# --- Recorded IVR greetings (regenerated from the handset) -------------------
# The recordings/ directory itself is tracked (via .gitkeep) so FreeSWITCH has
# a place to write main-menu.wav, but the recordings themselves are not.
/recordings/*
!/recordings/.gitkeep

# NOTE: bin/ lib/ mod/ include/ (aarch64 binaries), prompts/ (custom voice
# prompts), fonts/, htdocs/, certs/, conf/, scripts/ are intentionally
# tracked so this repo can fully redeploy the Raspberry Pi.
