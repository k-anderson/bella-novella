<include>
  <!-- Core paths -->
  <X-PRE-PROCESS cmd="set" data="base_dir=/usr/local/freeswitch"/>
  <X-PRE-PROCESS cmd="set" data="conf_dir=$${base_dir}/conf"/>
  <X-PRE-PROCESS cmd="set" data="log_dir=$${base_dir}/log"/>
  <X-PRE-PROCESS cmd="set" data="run_dir=$${base_dir}/run"/>
  <X-PRE-PROCESS cmd="set" data="db_dir=$${base_dir}/db"/>
  <X-PRE-PROCESS cmd="set" data="mod_dir=$${base_dir}/mod"/>

  <!-- Isolated ATA Ethernet network -->
  <X-PRE-PROCESS cmd="set" data="domain=192.168.50.1"/>
  <X-PRE-PROCESS cmd="set" data="bind_server_ip=192.168.50.1"/>
  <X-PRE-PROCESS cmd="set" data="ata_network_cidr=192.168.50.0/24"/>

  <!-- Small RTP range for local two-line appliance use -->
  <X-PRE-PROCESS cmd="set" data="rtp_start_port=16384"/>
  <X-PRE-PROCESS cmd="set" data="rtp_end_port=16484"/>

  <!-- POTS ATA audio -->
  <X-PRE-PROCESS cmd="set" data="global_codec_prefs=PCMU@20i"/>
  <X-PRE-PROCESS cmd="set" data="outbound_codec_prefs=PCMU@20i"/>

  <!-- Language + hold music. No stock sound files are shipped; every prompt is
       an absolute path under prompts_dir, so hold music is silence. -->
  <X-PRE-PROCESS cmd="set" data="default_language=en"/>
  <X-PRE-PROCESS cmd="set" data="default_dialect=us"/>
  <X-PRE-PROCESS cmd="set" data="default_voice=callie"/>
  <X-PRE-PROCESS cmd="set" data="hold_music=silence_stream://-1"/>

  <!-- Recordings directory -->
  <X-PRE-PROCESS cmd="set" data="recordings_dir=$${base_dir}/recordings"/>
  <X-PRE-PROCESS cmd="set" data="messages_dir=$${recordings_dir}/messages"/>

  <!-- Custom prompts (8 kHz mono WAV), tracked in the repo under prompts/ -->
  <X-PRE-PROCESS cmd="set" data="prompts_dir=$${base_dir}/prompts"/>

  <!-- Linear actuator relay commands -->
  <X-PRE-PROCESS cmd="set" data="disco_raise=/usr/bin/sudo /usr/local/freeswitch/scripts/disco-relay raise 5 15"/>
  <X-PRE-PROCESS cmd="set" data="disco_lower=/usr/bin/sudo /usr/local/freeswitch/scripts/disco-relay lower 5 15"/>
  <X-PRE-PROCESS cmd="set" data="disco_stop=/usr/bin/sudo /usr/local/freeswitch/scripts/disco-relay brake"/>
  <X-PRE-PROCESS cmd="set" data="disco_position=/usr/bin/sudo /usr/local/freeswitch/scripts/disco-relay position"/>

  <!-- IVR message store helper (runs as the freeswitch user; no sudo needed) -->
  <X-PRE-PROCESS cmd="set" data="bella_messages=/usr/local/freeswitch/scripts/bella-messages"/>
</include>
