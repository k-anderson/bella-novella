<include>
  <!-- Option 2: listen to messages, oldest first (newest 10 only). Each message
       is preceded by its numbered announcement (playback-announcement-<idx>).
       1 = next, 2 = previous; when a message finishes with no key it
       auto-advances, and after the last one it returns to the menu. Any other
       key replays the current announcement + message. Uses scripts/bella-messages
       playspec/step to map the index to a playback spec. -->

  <extension name="listen-messages">
    <condition field="destination_number" expression="^LISTEN_MESSAGES$">
      <action application="answer"/>
      <action application="set" data="msg_idx=1"/>
      <action application="transfer" data="MESSAGE_PLAY XML default"/>
    </condition>
  </extension>

  <!-- Resolve the current index to a playback spec (announcement + message), then
       re-enter so ${msg_play} is populated for the branch below. -->
  <extension name="message-play">
    <condition field="destination_number" expression="^MESSAGE_PLAY$">
      <action application="set" data="msg_play=${system($${bella_messages} playspec ${msg_idx})}"/>
      <action application="set" data="msg_nav="/>
      <action application="transfer" data="MESSAGE_PLAY2 XML default"/>
    </condition>
  </extension>

  <extension name="message-play2">
    <condition field="destination_number" expression="^MESSAGE_PLAY2$"/>
    <condition field="${msg_play}" expression="^$">
      <!-- Empty spec => no messages, or advanced past the last one. -->
      <action application="playback" data="$${prompts_dir}/vm-no_more_messages.wav"/>
      <action application="transfer" data="700 XML default"/>
      <!-- Non-empty: play announcement + message and collect one key. Any single
           key is captured so MESSAGE_NAV can branch: 1 = next, 2 = previous, and
           anything else replays the current announcement + message. No input
           leaves msg_nav empty and auto-advances. -->
      <anti-action application="play_and_get_digits"
                   data="0 1 1 3000 * ${msg_play} silence_stream://100 msg_nav '^[0-9*#]$' 3000"/>
      <anti-action application="transfer" data="MESSAGE_NAV XML default"/>
    </condition>
  </extension>

  <extension name="message-nav">
    <condition field="destination_number" expression="^MESSAGE_NAV$"/>
    <condition field="${msg_nav}" expression="^2$">
      <!-- 2 = previous -->
      <action application="set" data="msg_idx=${system($${bella_messages} step ${msg_idx} prev)}"/>
      <action application="transfer" data="MESSAGE_PLAY XML default"/>
      <anti-action application="transfer" data="MESSAGE_NAV2 XML default"/>
    </condition>
  </extension>

  <extension name="message-nav2">
    <condition field="destination_number" expression="^MESSAGE_NAV2$"/>
    <condition field="${msg_nav}" expression="^1?$">
      <!-- 1 = next, or empty = auto-advance after the message finished -->
      <action application="set" data="msg_idx=${system($${bella_messages} step ${msg_idx} next)}"/>
      <action application="transfer" data="MESSAGE_PLAY XML default"/>
      <!-- Any other key: replay the current announcement + message (no prompt). -->
      <anti-action application="transfer" data="MESSAGE_PLAY XML default"/>
    </condition>
  </extension>
</include>
