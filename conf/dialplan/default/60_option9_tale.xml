<include>
  <!-- ===================================================================
       Hidden option 9: "The Ember" — a branching fable Bella reads aloud.

       Entry: 10_inbound_and_menu.xml routes menu option 9 (secret, never
       announced) to TALE_OPEN. Each node narrates, then collects a single
       digit and transfers to a per-node dispatch pass (a fresh routing pass so
       the chosen digit can be tested in a <condition>). Invalid input or no
       choice plays a story-specific prompt (tale-invalid.wav) and re-offers the
       same node, keeping the caller inside the story. Endings play their close
       and return to the main menu (700). See STORY.md for the tree, the choice
       table, and the prompt scripts.

       Tree:
         TALE_OPEN    1=shield -> TALE_SHIELD   2=feed -> TALE_FEED   3=hidden -> STILL
         TALE_SHIELD  1=share  -> END SHARE     2=keep -> END HIDE
         TALE_FEED    1=burn   -> END REVEL     2=press on -> END ASH

       Every node resets max_forwards first: the story chains many transfers,
       which would otherwise exhaust the per-call budget and drop the call with
       EXCHANGE_ROUTING_ERROR.
       =================================================================== -->

  <!-- ===== Node: the ember at dusk (first fork) ===== -->
  <extension name="tale-open">
    <condition field="destination_number" expression="^TALE_OPEN$">
      <action application="set" data="max_forwards=70"/>
      <action application="set" data="tale_pick="/>
      <!-- 1=shield, 2=feed, 3=hidden (set it down). ~5s to choose; barge-in ok. -->
      <action application="play_and_get_digits"
              data="1 1 1 5000 * $${prompts_dir}/tale-open.wav silence_stream://100 tale_pick '^(1|2|3)$' 2000"/>
      <action application="transfer" data="TALE_OPEN_D XML default"/>
    </condition>
  </extension>

  <extension name="tale-open-shield">
    <condition field="destination_number" expression="^TALE_OPEN_D$"/>
    <condition field="${tale_pick}" expression="^1$">
      <action application="transfer" data="TALE_SHIELD XML default"/>
    </condition>
  </extension>

  <extension name="tale-open-feed">
    <condition field="destination_number" expression="^TALE_OPEN_D$"/>
    <condition field="${tale_pick}" expression="^2$">
      <action application="transfer" data="TALE_FEED XML default"/>
    </condition>
  </extension>

  <extension name="tale-open-still">
    <condition field="destination_number" expression="^TALE_OPEN_D$"/>
    <condition field="${tale_pick}" expression="^3$">
      <action application="transfer" data="TALE_END_STILL XML default"/>
    </condition>
  </extension>

  <!-- Invalid / no choice: story-specific nudge, then re-offer this node. -->
  <extension name="tale-open-invalid">
    <condition field="destination_number" expression="^TALE_OPEN_D$">
      <action application="playback" data="$${prompts_dir}/tale-invalid.wav"/>
      <action application="transfer" data="TALE_OPEN XML default"/>
    </condition>
  </extension>

  <!-- ===== Node: shield the ember (the lost ones in the dark) ===== -->
  <extension name="tale-shield">
    <condition field="destination_number" expression="^TALE_SHIELD$">
      <action application="set" data="max_forwards=70"/>
      <action application="set" data="tale_pick="/>
      <!-- 1=share the flame, 2=keep it and walk alone. -->
      <action application="play_and_get_digits"
              data="1 1 1 5000 * $${prompts_dir}/tale-shield.wav silence_stream://100 tale_pick '^(1|2)$' 2000"/>
      <action application="transfer" data="TALE_SHIELD_D XML default"/>
    </condition>
  </extension>

  <extension name="tale-shield-share">
    <condition field="destination_number" expression="^TALE_SHIELD_D$"/>
    <condition field="${tale_pick}" expression="^1$">
      <action application="transfer" data="TALE_END_SHARE XML default"/>
    </condition>
  </extension>

  <extension name="tale-shield-hide">
    <condition field="destination_number" expression="^TALE_SHIELD_D$"/>
    <condition field="${tale_pick}" expression="^2$">
      <action application="transfer" data="TALE_END_HIDE XML default"/>
    </condition>
  </extension>

  <extension name="tale-shield-invalid">
    <condition field="destination_number" expression="^TALE_SHIELD_D$">
      <action application="playback" data="$${prompts_dir}/tale-invalid.wav"/>
      <action application="transfer" data="TALE_SHIELD XML default"/>
    </condition>
  </extension>

  <!-- ===== Node: feed the ember (the map begins to burn) ===== -->
  <extension name="tale-feed">
    <condition field="destination_number" expression="^TALE_FEED$">
      <action application="set" data="max_forwards=70"/>
      <action application="set" data="tale_pick="/>
      <!-- 1=burn the whole book and dance, 2=press on by remaining light. -->
      <action application="play_and_get_digits"
              data="1 1 1 5000 * $${prompts_dir}/tale-feed.wav silence_stream://100 tale_pick '^(1|2)$' 2000"/>
      <action application="transfer" data="TALE_FEED_D XML default"/>
    </condition>
  </extension>

  <extension name="tale-feed-revel">
    <condition field="destination_number" expression="^TALE_FEED_D$"/>
    <condition field="${tale_pick}" expression="^1$">
      <action application="transfer" data="TALE_END_REVEL XML default"/>
    </condition>
  </extension>

  <extension name="tale-feed-ash">
    <condition field="destination_number" expression="^TALE_FEED_D$"/>
    <condition field="${tale_pick}" expression="^2$">
      <action application="transfer" data="TALE_END_ASH XML default"/>
    </condition>
  </extension>

  <extension name="tale-feed-invalid">
    <condition field="destination_number" expression="^TALE_FEED_D$">
      <action application="playback" data="$${prompts_dir}/tale-invalid.wav"/>
      <action application="transfer" data="TALE_FEED XML default"/>
    </condition>
  </extension>

  <!-- ===== Endings: play the fable's close, then back to the menu ===== -->
  <extension name="tale-end-share">
    <condition field="destination_number" expression="^TALE_END_SHARE$">
      <action application="playback" data="$${prompts_dir}/tale-end-share.wav"/>
      <action application="sleep" data="1500"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <extension name="tale-end-hide">
    <condition field="destination_number" expression="^TALE_END_HIDE$">
      <action application="playback" data="$${prompts_dir}/tale-end-hide.wav"/>
      <action application="sleep" data="1500"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <extension name="tale-end-revel">
    <condition field="destination_number" expression="^TALE_END_REVEL$">
      <action application="playback" data="$${prompts_dir}/tale-end-revel.wav"/>
      <action application="sleep" data="1500"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <extension name="tale-end-ash">
    <condition field="destination_number" expression="^TALE_END_ASH$">
      <action application="playback" data="$${prompts_dir}/tale-end-ash.wav"/>
      <action application="sleep" data="1500"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <extension name="tale-end-still">
    <condition field="destination_number" expression="^TALE_END_STILL$">
      <action application="playback" data="$${prompts_dir}/tale-end-still.wav"/>
      <action application="sleep" data="1500"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>
</include>
