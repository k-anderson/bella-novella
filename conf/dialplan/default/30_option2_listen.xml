<include>
  <!-- Option 2: listen to messages, newest first (newest 10 only).

       Each message has a lead-in announcement (playback-announcement-<idx>)
       played as a SEPARATE prompt before the message itself:
         - No key while a message plays: auto-advance to the next message, WITH
           its announcement.
         - 1 = next, 2 = previous: play that message directly, announcement skipped.
         - Any key while an announcement plays: skip straight to the message.
         - Any other key while a message plays: replay the current message.
       After the last message it returns to the menu (700). scripts/bella-messages
       maps the index to files (resolve/announcement/step).

       Flow: ANNOUNCE -> ANNOUNCE_PLAY -> RESOLVE -> PLAY, then the pressed key is
       handled by the MESSAGE_KEY_PREV -> _NEXT -> _DEFAULT chain, which loops back. -->

  <!-- Entry (from the menu): start at the newest message. -->
  <extension name="listen-messages">
    <condition field="destination_number" expression="^LISTEN_MESSAGES$">
      <action application="answer"/>
      <action application="set" data="msg_idx=1"/>
      <action application="transfer" data="MESSAGE_ANNOUNCE XML default"/>
    </condition>
  </extension>

  <!-- Resolve the announcement prompt for msg_idx, then re-enter so ${msg_ann}
       is set for the branch in message-announce-play. -->
  <extension name="message-announce">
    <condition field="destination_number" expression="^MESSAGE_ANNOUNCE$">
      <action application="set" data="msg_ann=${system($${bella_messages} announcement ${msg_idx})}"/>
      <action application="transfer" data="MESSAGE_ANNOUNCE_PLAY XML default"/>
    </condition>
  </extension>

  <!-- Play the announcement as a lead-in (any key skips the rest), then the
       message. No announcement file (missing, or past the end) goes straight
       to the message. -->
  <extension name="message-announce-play">
    <condition field="destination_number" expression="^MESSAGE_ANNOUNCE_PLAY$"/>
    <condition field="${msg_ann}" expression="^$">
      <action application="transfer" data="MESSAGE_RESOLVE XML default"/>
      <anti-action application="play_and_get_digits"
                   data="0 1 1 100 * ${msg_ann} silence_stream://10 msg_skip '^[0-9*#]$' 100"/>
      <anti-action application="transfer" data="MESSAGE_RESOLVE XML default"/>
    </condition>
  </extension>

  <!-- Resolve msg_idx to a file, then re-enter so ${msg_file} is set for the
       branch in message-play. max_forwards is reset every cycle because each
       transfer decrements it; long browsing would otherwise exhaust the per-call
       budget and drop the call with EXCHANGE_ROUTING_ERROR. -->
  <extension name="message-resolve">
    <condition field="destination_number" expression="^MESSAGE_RESOLVE$">
      <action application="set" data="max_forwards=70"/>
      <action application="set" data="msg_file=${system($${bella_messages} resolve ${msg_idx})}"/>
      <action application="set" data="msg_nav="/>
      <action application="transfer" data="MESSAGE_PLAY XML default"/>
    </condition>
  </extension>

  <!-- Play the message and collect one key into msg_nav. Empty msg_file (empty
       store, or stepped past the last message) goes to MESSAGE_END. Otherwise
       flush any digit left over from skipping the announcement (so it can't
       instantly advance), play the message, and hand the key to the msg_nav
       chain starting at MESSAGE_KEY_PREV. -->
  <extension name="message-play">
    <condition field="destination_number" expression="^MESSAGE_PLAY$"/>
    <condition field="${msg_file}" expression="^$">
      <action application="transfer" data="MESSAGE_END XML default"/>
      <anti-action application="flush_dtmf"/>
      <anti-action application="play_and_get_digits"
                   data="0 1 1 500 * ${msg_file} silence_stream://100 msg_nav '^[0-9*#]$' 3000"/>
      <anti-action application="transfer" data="MESSAGE_KEY_PREV XML default"/>
    </condition>
  </extension>

  <!-- End of the listening session. Two ways to arrive here with an empty msg_file:
         - msg_idx == 0: the caller stepped past the last message (auto-advance, or
           pressing 1 on the final one), i.e. they heard everything -> play the
           reflective playback-end sign-off. While it plays, 9 = "keep going":
           continue newest-first into the full archive past the curated window
           (see PLAYBACK_END_KEY / DRAWER_*). Any other key or none -> menu.
         - msg_idx >= 1: resolve found nothing at the very first index, i.e. the
           store was empty -> keep the original "nothing here, come back" prompt. -->
  <extension name="message-end">
    <condition field="destination_number" expression="^MESSAGE_END$"/>
    <condition field="${msg_idx}" expression="^0$">
      <action application="set" data="drawer_key="/>
      <action application="play_and_get_digits"
              data="0 1 1 1500 # $${prompts_dir}/playback-end.wav silence_stream://10 drawer_key '^9$' 3000"/>
      <action application="transfer" data="PLAYBACK_END_KEY XML default"/>
      <anti-action application="playback" data="$${prompts_dir}/vm-no_more_messages.wav"/>
      <anti-action application="sleep" data="1500"/>
      <anti-action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <!-- Decide what the key pressed during playback-end means:
         9 -> open "Bella's drawer of secrets": play the playback-special intro,
              then browse the whole archive newest-first from just past the
              curated window (drawer-start = PLAYBACK_LIMIT+1). No lead-in
              announcements; a tone separates each message. 1 = next, 2 = previous,
              7 = delete the current message, any other key = replay, no key =
              auto-advance.
         anything else / nothing -> back to the menu. -->
  <extension name="playback-end-key">
    <condition field="destination_number" expression="^PLAYBACK_END_KEY$"/>
    <condition field="${drawer_key}" expression="^9$">
      <action application="playback" data="$${prompts_dir}/playback-special.wav"/>
      <action application="set" data="drawer_idx=${system($${bella_messages} drawer-start)}"/>
      <action application="transfer" data="DRAWER_RESOLVE XML default"/>
      <anti-action application="sleep" data="500"/>
      <anti-action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <!-- Bella's drawer of secrets (dial 9): the full archive, newest-first, no
       lead-in announcements. Mirrors MESSAGE_RESOLVE/PLAY but over
       resolve-all/step-all so it can reach messages older than the curated
       window. The helpers re-list the store on every call, so deleting (7) takes
       effect at once and every index adapts as if the message had never been
       stored. max_forwards is reset each cycle (every transfer decrements it). -->
  <extension name="drawer-resolve">
    <condition field="destination_number" expression="^DRAWER_RESOLVE$">
      <action application="set" data="max_forwards=70"/>
      <action application="set" data="drawer_file=${system($${bella_messages} resolve-all ${drawer_idx})}"/>
      <action application="set" data="drawer_nav="/>
      <action application="transfer" data="DRAWER_PLAY XML default"/>
    </condition>
  </extension>

  <!-- Empty drawer_file (drawer_idx == 0: stepped past the oldest, or 9 pressed
       with nothing beyond the window) -> sign off and return to the menu.
       Otherwise sound a short tone as a separator, flush any leftover digit, play
       the message, and collect one key into drawer_nav. -->
  <extension name="drawer-play">
    <condition field="destination_number" expression="^DRAWER_PLAY$"/>
    <condition field="${drawer_file}" expression="^$">
      <action application="transfer" data="DRAWER_END XML default"/>
      <anti-action application="playback" data="tone_stream://%(200,0,660)"/>
      <anti-action application="flush_dtmf"/>
      <anti-action application="play_and_get_digits"
                   data="0 1 1 500 * ${drawer_file} silence_stream://100 drawer_nav '^[0-9*#]$' 3000"/>
      <anti-action application="transfer" data="DRAWER_KEY_PREV XML default"/>
    </condition>
  </extension>

  <extension name="drawer-key-prev">
    <condition field="destination_number" expression="^DRAWER_KEY_PREV$"/>
    <condition field="${drawer_nav}" expression="^2$">
      <!-- 2 = previous message in the full archive. -->
      <action application="set" data="drawer_idx=${system($${bella_messages} step-all ${drawer_idx} prev)}"/>
      <action application="transfer" data="DRAWER_RESOLVE XML default"/>
      <anti-action application="transfer" data="DRAWER_KEY_NEXT XML default"/>
    </condition>
  </extension>

  <extension name="drawer-key-next">
    <condition field="destination_number" expression="^DRAWER_KEY_NEXT$"/>
    <condition field="${drawer_nav}" expression="^1$">
      <!-- 1 = next message in the full archive. -->
      <action application="set" data="drawer_idx=${system($${bella_messages} step-all ${drawer_idx} next)}"/>
      <action application="transfer" data="DRAWER_RESOLVE XML default"/>
      <anti-action application="transfer" data="DRAWER_KEY_DELETE XML default"/>
    </condition>
  </extension>

  <!-- 7 = delete the current message. The store re-lists on every helper call, so
       after the delete the same drawer_idx now resolves to the message that was
       next-older (it slides into this slot); if the oldest was deleted, resolve-all
       returns empty and DRAWER_RESOLVE -> DRAWER_PLAY falls through to DRAWER_END. -->
  <extension name="drawer-key-delete">
    <condition field="destination_number" expression="^DRAWER_KEY_DELETE$"/>
    <condition field="${drawer_nav}" expression="^7$">
      <action application="set" data="drawer_deleted=${system($${bella_messages} delete-all ${drawer_idx})}"/>
      <action application="transfer" data="DRAWER_RESOLVE XML default"/>
      <anti-action application="transfer" data="DRAWER_KEY_DEFAULT XML default"/>
    </condition>
  </extension>

  <extension name="drawer-key-default">
    <condition field="destination_number" expression="^DRAWER_KEY_DEFAULT$"/>
    <condition field="${drawer_nav}" expression="^$">
      <!-- No key = message finished on its own: auto-advance, no announcement. -->
      <action application="set" data="drawer_idx=${system($${bella_messages} step-all ${drawer_idx} next)}"/>
      <action application="transfer" data="DRAWER_RESOLVE XML default"/>
      <!-- Any other key: replay the current message. -->
      <anti-action application="transfer" data="DRAWER_RESOLVE XML default"/>
    </condition>
  </extension>

  <!-- Reached the oldest stored message: a plain sign-off (no 9 affordance, so
       it can't loop) and back to the menu. -->
  <extension name="drawer-end">
    <condition field="destination_number" expression="^DRAWER_END$">
      <action application="playback" data="$${prompts_dir}/playback-end.wav"/>
      <action application="sleep" data="1500"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <!-- Key handling after a message: a chain of single-value checks on msg_nav
       (2 = previous here, then 1 = next, then empty/other = default). -->
  <extension name="message-key-prev">
    <condition field="destination_number" expression="^MESSAGE_KEY_PREV$"/>
    <condition field="${msg_nav}" expression="^2$">
      <!-- 2 = previous message, played directly (announcement skipped). -->
      <action application="set" data="msg_idx=${system($${bella_messages} step ${msg_idx} prev)}"/>
      <action application="transfer" data="MESSAGE_RESOLVE XML default"/>
      <anti-action application="transfer" data="MESSAGE_KEY_NEXT XML default"/>
    </condition>
  </extension>

  <extension name="message-key-next">
    <condition field="destination_number" expression="^MESSAGE_KEY_NEXT$"/>
    <condition field="${msg_nav}" expression="^1$">
      <!-- 1 = next message, played directly (announcement skipped). -->
      <action application="set" data="msg_idx=${system($${bella_messages} step ${msg_idx} next)}"/>
      <action application="transfer" data="MESSAGE_RESOLVE XML default"/>
      <anti-action application="transfer" data="MESSAGE_KEY_DEFAULT XML default"/>
    </condition>
  </extension>

  <extension name="message-key-default">
    <condition field="destination_number" expression="^MESSAGE_KEY_DEFAULT$"/>
    <condition field="${msg_nav}" expression="^$">
      <!-- No key = message finished on its own: advance to the next WITH its announcement. -->
      <action application="set" data="msg_idx=${system($${bella_messages} step ${msg_idx} next)}"/>
      <action application="transfer" data="MESSAGE_ANNOUNCE XML default"/>
      <!-- Any other key: replay the current message (no announcement). -->
      <anti-action application="transfer" data="MESSAGE_RESOLVE XML default"/>
    </condition>
  </extension>
</include>
