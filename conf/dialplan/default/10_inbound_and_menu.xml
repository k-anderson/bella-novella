<include>
  <!-- ===================================================================
       Inbound routing + main menu (700).

       The ATA off-hook auto-dials 700; any other dialed number is also routed
       to 700 by all-calls-to-menu (below). The menu collects one option:

         1   = intercom the other phone  (CALL_OTHER,      20_option1_intercom.xml)
         2   = listen to messages        (LISTEN_MESSAGES, 30_option2_listen.xml)
         3   = leave a message           (LEAVE_MESSAGE,   40_option3_leave.xml)
         911 = raise the disco ball      (DISCO_RAISE,     50_disco_controls.xml)
         811 = lower the disco ball      (DISCO_LOWER,     50_disco_controls.xml)
         411 = about the art car         (dispatch-about, this file)
         11  = stop the disco ball       (DISCO_STOP,      50_disco_controls.xml)
         101-104 = dial that SIP line     (00_extensions.xml)
         0   = dial SIP line 104          (00_extensions.xml)
         7   = hidden fable "The Ember"   (TALE_OPEN,       60_option7_tale.xml), unspoken
         9   = hidden principles survey   (SURVEY_START,    80_option9_survey.xml), unspoken
         5   = hidden number game         (GAME_START,      70_option5_game.xml), unspoken
       Anything else plays a random "invalid" prompt. Every path returns here.
       =================================================================== -->

  <!-- First entry of the call: play the full greeting once, then remember it. -->
  <extension name="menu-first">
    <condition field="destination_number" expression="^700$"/>
    <condition field="${menu_greeted}" expression="^$">
      <action application="answer"/>
      <action application="sleep" data="100"/>
      <!-- Reset the per-call transfer budget; the IVR loops via many transfers
           and would otherwise exhaust max_forwards and drop the call. -->
      <action application="set" data="max_forwards=70"/>
      <action application="set" data="menu_greeted=true"/>
      <action application="set" data="bella_opt="/>
      <!-- min=1 max=3, '*' terminator, validate to the known options; 2s
           inter-digit timeout resolves 1 vs 11 vs 101-104. -->
      <action application="play_and_get_digits"
              data="1 3 1 7000 * $${prompts_dir}/main-menu.wav silence_stream://100 bella_opt '^(0|1|2|3|5|7|9|911|811|411|10[1-4]|11)$' 2000"/>
      <action application="transfer" data="DISPATCH XML default"/>
    </condition>
  </extension>

  <!-- Every later return to the menu (after an action/invalid): short greeting.
       One of the main-menu-short-variant-N prompts is chosen at random. -->
  <extension name="menu-repeat">
    <condition field="destination_number" expression="^700$"/>
    <condition field="${menu_greeted}" expression="^true$">
      <action application="set" data="max_forwards=70"/>
      <action application="set" data="bella_opt="/>
      <action application="set" data="menu_prompt=${system($${bella_messages} pick main-menu-short-variant)}"/>
      <action application="play_and_get_digits"
              data="1 3 1 7000 * ${menu_prompt} silence_stream://100 bella_opt '^(0|1|2|3|5|7|9|911|811|411|10[1-4]|11)$' 2000"/>
      <action application="transfer" data="DISPATCH XML default"/>
    </condition>
  </extension>

  <!-- Dispatch runs in a fresh routing pass so ${bella_opt} is populated. Each
       option has its own extension; the final catch-all handles invalid/empty
       input. Whichever matches transfers away before the catch-all runs. -->
  <extension name="dispatch-call">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^1$">
      <action application="transfer" data="CALL_OTHER XML default"/>
    </condition>
  </extension>

  <extension name="dispatch-listen">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^2$">
      <action application="transfer" data="LISTEN_MESSAGES XML default"/>
    </condition>
  </extension>

  <extension name="dispatch-leave">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^3$">
      <action application="transfer" data="LEAVE_MESSAGE XML default"/>
    </condition>
  </extension>

  <extension name="dispatch-raise">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^911$">
      <action application="transfer" data="DISCO_RAISE XML default"/>
    </condition>
  </extension>

  <extension name="dispatch-lower">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^811$">
      <action application="transfer" data="DISCO_LOWER XML default"/>
    </condition>
  </extension>

  <extension name="dispatch-stop">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^11$">
      <action application="transfer" data="DISCO_STOP XML default"/>
    </condition>
  </extension>

  <!-- Option 411: describe the art car, its creators, and the build, then
       return to the menu. The about.wav prompt is added separately. -->
  <extension name="dispatch-about">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^411$">
      <action application="playback" data="$${prompts_dir}/about-1.wav"/>
      <action application="sleep" data="1000"/>
      <action application="playback" data="$${prompts_dir}/about-2.wav"/>
      <action application="sleep" data="1000"/>      
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <!-- Dial a SIP line (101-104) straight from the menu; the dial-1NN extensions
       in 00_extensions.xml ring the phone. -->
  <extension name="dispatch-extension">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^(10[1-4])$">
      <action application="transfer" data="$1 XML default"/>
    </condition>
  </extension>

  <!-- Option 0: dial SIP line 104 (dial-104 in 00_extensions.xml rings it). -->
  <extension name="dispatch-zero">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^0$">
      <action application="transfer" data="104 XML default"/>
    </condition>
  </extension>

  <!-- Hidden option 7: Bella's branching fable "The Ember" (60_option7_tale.xml). Never
       announced in any greeting; only callers who dial 7 find it. -->
  <extension name="dispatch-story">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^7$">
      <action application="transfer" data="TALE_OPEN XML default"/>
    </condition>
  </extension>

  <!-- Hidden option 9: Bella's principles survey (80_option9_survey.xml). Never
       announced in any greeting; only callers who dial 9 find it. -->
  <extension name="dispatch-survey">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^9$">
      <action application="transfer" data="SURVEY_START XML default"/>
    </condition>
  </extension>

  <!-- Hidden option 5: Bella's "guess my number" game (70_option5_game.xml). Never
       announced in any greeting; only callers who dial 5 find it. -->
  <extension name="dispatch-game">
    <condition field="destination_number" expression="^DISPATCH$"/>
    <condition field="${bella_opt}" expression="^5$">
      <action application="transfer" data="GAME_START XML default"/>
    </condition>
  </extension>

  <!-- Catch-all: invalid or no selection -> one of ten random prompts. Collect
       ANY keypad entry (not just valid options): a valid option is dispatched, any
       other entry loops back here for a fresh scold, and only silence (a timeout,
       leaving bella_opt empty) falls back to the menu greeting. A valid option can
       be pressed over the prompt and is acted on immediately. -->
  <extension name="dispatch-invalid">
    <condition field="destination_number" expression="^DISPATCH$">
      <!-- Reset the per-call transfer budget: repeated invalid entries loop here
           via transfers and would otherwise exhaust max_forwards and drop the call. -->
      <action application="set" data="max_forwards=70"/>
      <action application="set" data="bella_opt="/>
      <action application="play_and_get_digits"
              data="1 3 1 500 * ${system($${bella_messages} pick invalid-entry)} silence_stream://100 bella_opt '^[0-9#]+$' 2000"/>
      <action application="sleep" data="500"/>
      <action application="transfer" data="DISPATCH_AFTER_INVALID XML default"/>
    </condition>
  </extension>

  <!-- Any entry (valid or not) goes back through DISPATCH: a valid option is acted
       on, an invalid one replays the scold. Only an empty bella_opt (timeout, no
       key pressed) returns to the menu greeting. -->
  <extension name="dispatch-after-invalid">
    <condition field="destination_number" expression="^DISPATCH_AFTER_INVALID$"/>
    <condition field="${bella_opt}" expression="^$">
      <action application="sleep" data="500"/>
      <action application="transfer" data="700 XML default"/>
      <anti-action application="transfer" data="DISPATCH XML default"/>
    </condition>
  </extension>

  <!-- Any inbound call (off-hook auto-dial 700, or any dialed number) enters the
       menu. Placed last and numeric-only, so it never shadows the lettered
       internal targets (CALL_OTHER, LEAVE_MESSAGE, DISCO_RAISE, ...). -->
  <extension name="all-calls-to-menu">
    <condition field="destination_number" expression="^[0-9*#]+$">
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>
</include>
