<include>
  <!-- Any inbound call from the ATA (off-hook auto-dial 700, or any dialed
       number) is routed to the main menu at 700. The numeric pattern here does
       not match the internal DISCO_* targets (which contain letters), so those
       are handled by their own extensions above without being re-routed. -->
  <extension name="disco-all-calls-to-menu">
    <condition field="destination_number" expression="^[0-9*#]+$">
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>
</include>
