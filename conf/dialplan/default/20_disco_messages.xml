<include>
  <!-- ===================================================================
       Message features for the Bella Novella IVR.

       Option 2 (DISCO_LEAVE):  play a prompt, beep, record up to 15s.
       Option 3 (DISCO_LISTEN): play stored messages oldest-first with
                                1 = previous, 2 = next, auto-advance at the
                                end of a message, and no other actions.

       Storage/rotation (keep newest 10, discard no-speech) is handled by the
       scripts/disco-messages helper, invoked via ${system(...)}. Prompts are
       stock placeholders (marked below) and may be re-recorded later.
       =================================================================== -->

  <!-- Option 2: leave a message. -->
  <extension name="disco-leave">
    <condition field="destination_number" expression="^DISCO_LEAVE$">
      <action application="answer"/>
      <!-- Placeholder prompt: "record your message". -->
      <action application="playback" data="voicemail/vm-record_message.wav"/>
      <!-- Beep, then begin recording. -->
      <action application="playback" data="tone_stream://%(500,0,800)"/>
      <!-- Discard recordings shorter than 2s (treated as no speech). -->
      <action application="set" data="record_min_sec=2"/>
      <action application="set" data="playback_terminators=none"/>
      <!-- 15s cap; lenient silence detection (threshold 300, 5 silence hits). -->
      <action application="record" data="$${messages_dir}/msg_${strftime(%Y%m%d%H%M%S)}_${uuid}.wav 15 300 5"/>
      <!-- Prune empties and keep only the newest 10. -->
      <action application="set" data="disco_rotate=${system($${disco_messages} rotate)}"/>
      <!-- Placeholder prompt: "saved". -->
      <action application="playback" data="voicemail/vm-saved.wav"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <!-- Option 3: listen to messages, oldest first. -->
  <extension name="disco-listen">
    <condition field="destination_number" expression="^DISCO_LISTEN$">
      <action application="answer"/>
      <action application="set" data="msg_idx=1"/>
      <action application="transfer" data="DISCO_MSG_PLAY XML default"/>
    </condition>
  </extension>

  <!-- Resolve the current index to a file path, then re-enter so ${msg_file}
       is populated for the branch below. -->
  <extension name="disco-msg-play">
    <condition field="destination_number" expression="^DISCO_MSG_PLAY$">
      <action application="set" data="msg_file=${system($${disco_messages} resolve ${msg_idx})}"/>
      <action application="set" data="msg_nav="/>
      <action application="transfer" data="DISCO_MSG_PLAY2 XML default"/>
    </condition>
  </extension>

  <extension name="disco-msg-play2">
    <condition field="destination_number" expression="^DISCO_MSG_PLAY2$"/>
    <condition field="${msg_file}" expression="^$">
      <!-- Empty path => no messages, or advanced past the last one. -->
      <action application="playback" data="voicemail/vm-no_more_messages.wav"/>
      <action application="transfer" data="700 XML default"/>
      <!-- Non-empty: play the message and collect a nav digit (1 or 2). The
           '*' terminator keeps input to the two nav keys; anything else or no
           input leaves msg_nav empty and auto-advances. -->
      <anti-action application="play_and_get_digits"
                   data="0 1 1 3000 * ${msg_file} '' msg_nav '^(1|2)$' 3000"/>
      <anti-action application="transfer" data="DISCO_MSG_NAV XML default"/>
    </condition>
  </extension>

  <extension name="disco-msg-nav">
    <condition field="destination_number" expression="^DISCO_MSG_NAV$"/>
    <condition field="${msg_nav}" expression="^1$">
      <!-- 1 = previous -->
      <action application="set" data="msg_idx=${system($${disco_messages} step ${msg_idx} prev)}"/>
      <action application="transfer" data="DISCO_MSG_PLAY XML default"/>
      <!-- 2 = next, or empty = auto-advance after the message finished -->
      <anti-action application="set" data="msg_idx=${system($${disco_messages} step ${msg_idx} next)}"/>
      <anti-action application="transfer" data="DISCO_MSG_PLAY XML default"/>
    </condition>
  </extension>
</include>
