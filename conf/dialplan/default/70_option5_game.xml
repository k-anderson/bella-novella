<include>
  <!-- ===================================================================
       Hidden option 5: "Guess My Number" — Bella picks a secret 1-9 and the
       caller guesses one keypress at a time.

       Entry: 10_inbound_and_menu.xml routes menu option 5 (secret, never
       announced) to GAME_START. Flow:

         GAME_START  pick secret, reset tries, queue the rules, -> GAME_ASK
         GAME_ASK    play ${game_prompt} and collect one digit (1-9) -> GAME_EVAL
         GAME_EVAL   empty/invalid -> nudge + re-ask;
                     else ask scripts/bella-game for a verdict -> GAME_VERDICT
         GAME_VERDICT  hit  -> GAME_WIN
                       lose -> GAME_LOSE
                       high -> bump tries, queue "higher", re-ask
                       low  -> bump tries, queue "lower",  re-ask
         GAME_WIN / GAME_LOSE  play the close, back to the menu (700)

       Prompts (intro, higher/lower, invalid) are played *inside* GAME_ASK's
       play_and_get_digits as ${game_prompt}, so any key pressed while they play
       is taken as the guess. That lets a returning caller barge in and skip
       through the prompts by guessing as they hear them. Each step just sets
       game_prompt to the file it wants played next and transfers to GAME_ASK.

       The secret is never spoken (no TTS needed) and never revealed on a loss.
       Range 1-9 is passed literally; the try cap is $${game_tries_max}. Every
       GAME_ASK resets max_forwards (the loop chains many transfers). See GAME.md
       for the prompt scripts and the bella-game helper contract.
       =================================================================== -->

  <extension name="game-start">
    <condition field="destination_number" expression="^GAME_START$">
      <action application="set" data="game_secret=${system($${bella_game} secret 1 9)}"/>
      <action application="set" data="game_tries=0"/>
      <action application="set" data="game_prompt=${system($${bella_messages} pick game-intro)}"/>
      <action application="transfer" data="GAME_ASK XML default"/>
    </condition>
  </extension>

  <!-- Collect a single guess. Reset the per-call transfer budget first. The
       prompt for this step (${game_prompt}: intro, higher/lower, or invalid) is
       played as the FILE arg, so a key pressed while it plays is the guess —
       letting returning callers barge in and skip ahead. -->
  <extension name="game-ask">
    <condition field="destination_number" expression="^GAME_ASK$">
      <action application="set" data="max_forwards=70"/>
      <action application="set" data="game_guess="/>
      <!-- args: min max tries timeout terminators FILE INVALID-AUDIO VAR REGEX digit-timeout.
           FILE is the current step's prompt (barge-in-able); INVALID-AUDIO is silence. -->
      <action application="play_and_get_digits"
              data="1 1 1 7000 # ${game_prompt} silence_stream://100 game_guess '^[1-9]$' 2000"/>
      <action application="transfer" data="GAME_EVAL XML default"/>
    </condition>
  </extension>

  <!-- No digit (timeout) or a rejected key (0 / '#'): nudge and re-ask, without
       burning a try. Runs before game-eval, so the verdict is only asked for a
       real 1-9 guess. -->
  <extension name="game-eval-empty">
    <condition field="destination_number" expression="^GAME_EVAL$"/>
    <condition field="${game_guess}" expression="^$">
      <action application="set" data="game_prompt=$${prompts_dir}/game-invalid.wav"/>
      <action application="transfer" data="GAME_ASK XML default"/>
    </condition>
  </extension>

  <extension name="game-eval">
    <condition field="destination_number" expression="^GAME_EVAL$">
      <action application="set" data="game_verdict=${system($${bella_game} verdict 1 9 ${game_secret} ${game_guess} ${game_tries} $${game_tries_max})}"/>
      <action application="transfer" data="GAME_VERDICT XML default"/>
    </condition>
  </extension>

  <extension name="game-verdict-hit">
    <condition field="destination_number" expression="^GAME_VERDICT$"/>
    <condition field="${game_verdict}" expression="^hit$">
      <action application="transfer" data="GAME_WIN XML default"/>
    </condition>
  </extension>

  <extension name="game-verdict-lose">
    <condition field="destination_number" expression="^GAME_VERDICT$"/>
    <condition field="${game_verdict}" expression="^lose$">
      <action application="transfer" data="GAME_LOSE XML default"/>
    </condition>
  </extension>

  <extension name="game-verdict-high">
    <condition field="destination_number" expression="^GAME_VERDICT$"/>
    <condition field="${game_verdict}" expression="^high$">
      <action application="set" data="game_tries=${system($${bella_game} incr ${game_tries})}"/>
      <action application="set" data="game_prompt=${system($${bella_messages} pick game-higher)}"/>
      <action application="transfer" data="GAME_ASK XML default"/>
    </condition>
  </extension>

  <extension name="game-verdict-low">
    <condition field="destination_number" expression="^GAME_VERDICT$"/>
    <condition field="${game_verdict}" expression="^low$">
      <action application="set" data="game_tries=${system($${bella_game} incr ${game_tries})}"/>
      <action application="set" data="game_prompt=${system($${bella_messages} pick game-lower)}"/>
      <action application="transfer" data="GAME_ASK XML default"/>
    </condition>
  </extension>

  <!-- Defensive catch-all (e.g. the helper is unavailable): nudge and re-ask. -->
  <extension name="game-verdict-other">
    <condition field="destination_number" expression="^GAME_VERDICT$">
      <action application="set" data="game_prompt=$${prompts_dir}/game-invalid.wav"/>
      <action application="transfer" data="GAME_ASK XML default"/>
    </condition>
  </extension>

  <extension name="game-win">
    <condition field="destination_number" expression="^GAME_WIN$">
      <action application="set" data="game_close=${system($${bella_messages} pick game-win)}"/>
      <action application="playback" data="${game_close}"/>
      <action application="sleep" data="1500"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <extension name="game-lose">
    <condition field="destination_number" expression="^GAME_LOSE$">
      <action application="set" data="game_close=${system($${bella_messages} pick game-lose)}"/>
      <action application="playback" data="${game_close}"/>
      <action application="sleep" data="1500"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>
</include>
