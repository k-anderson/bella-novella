<include>
  <!-- Option 3: leave a message (max 60s, discarded if too short/silent).
       Storage/retention is handled by scripts/bella-messages via ${system(...)}:
       messages are kept unless disk is low; playback is limited to the newest
       10. Prompts are stock placeholders and may be re-recorded later. -->
  <extension name="leave-message">
    <condition field="destination_number" expression="^LEAVE_MESSAGE$">
      <action application="answer"/>
      <!-- "record your message" prompt. -->
      <action application="playback" data="$${prompts_dir}/vm-record_message.wav"/>
      <!-- Beep, then begin recording. -->
      <action application="playback" data="tone_stream://%(500,0,800)"/>
      <!-- Discard recordings shorter than 2s (treated as no speech). -->
      <action application="set" data="record_min_sec=2"/>
      <!-- Any DTMF digit stops the recording. -->
      <action application="set" data="playback_terminators=any"/>
      <!-- 60s cap; lenient silence detection (threshold 300, 5 silence hits). -->
      <action application="record" data="$${messages_dir}/msg_${strftime(%Y%m%d%H%M%S)}_${uuid}.wav 60 300 5"/>
      <!-- Prune only if disk is low; keep everything otherwise. -->
      <action application="set" data="bella_rotate=${system($${bella_messages} rotate)}"/>
      <!-- "saved" prompt. -->
      <action application="playback" data="$${prompts_dir}/vm-saved.wav"/>
      <action application="sleep" data="500"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>
</include>
