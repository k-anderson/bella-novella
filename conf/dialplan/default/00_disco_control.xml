<include>
  <!-- IVR option 1 when caller is line 101: call line 102. -->
  <extension name="disco-call-other-from-101">
    <condition field="destination_number" expression="^DISCO_CALL_OTHER$"/>
    <condition field="${sip_from_user}" expression="^101$">
      <action application="set" data="hangup_after_bridge=true"/>
      <action application="set" data="continue_on_fail=true"/>
      <action application="set" data="effective_caller_id_number=101"/>
      <action application="set" data="effective_caller_id_name=Line 101"/>
      <action application="bridge" data="${sofia_contact(102@$${domain})}"/>
      <action application="playback" data="ivr/ivr-that_was_an_invalid_entry.wav"/>
      <action application="hangup" data="NO_USER_RESPONSE"/>
    </condition>
  </extension>

  <!-- IVR option 1 when caller is line 102: call line 101. -->
  <extension name="disco-call-other-from-102">
    <condition field="destination_number" expression="^DISCO_CALL_OTHER$"/>
    <condition field="${sip_from_user}" expression="^102$">
      <action application="set" data="hangup_after_bridge=true"/>
      <action application="set" data="continue_on_fail=true"/>
      <action application="set" data="effective_caller_id_number=102"/>
      <action application="set" data="effective_caller_id_name=Line 102"/>
      <action application="bridge" data="${sofia_contact(101@$${domain})}"/>
      <action application="playback" data="ivr/ivr-that_was_an_invalid_entry.wav"/>
      <action application="hangup" data="NO_USER_RESPONSE"/>
    </condition>
  </extension>

  <!-- Safety fallback if option 1 is selected from an unexpected SIP user. -->
  <extension name="disco-call-other-unknown-line">
    <condition field="destination_number" expression="^DISCO_CALL_OTHER$">
      <action application="playback" data="ivr/ivr-that_was_an_invalid_entry.wav"/>
      <action application="hangup" data="CALL_REJECTED"/>
    </condition>
  </extension>

  <!-- IVR option 2: raise the actuator. The relay script prints "busy" if a
       movement is already running, otherwise "started"; branch on the result. -->
  <extension name="disco-raise">
    <condition field="destination_number" expression="^DISCO_RAISE$">
      <action application="set" data="disco_move=${system($${disco_raise})}"/>
      <action application="transfer" data="DISCO_RAISE_RESULT XML default"/>
    </condition>
  </extension>

  <extension name="disco-raise-result">
    <condition field="destination_number" expression="^DISCO_RAISE_RESULT$"/>
    <condition field="${disco_move}" expression="busy">
      <action application="playback" data="ivr/ivr-that_was_an_invalid_entry.wav"/>
      <action application="hangup" data="NORMAL_CLEARING"/>
      <anti-action application="playback" data="tone_stream://%(300,100,700);%(300,100,900);%(300,100,1100)"/>
      <anti-action application="hangup" data="NORMAL_CLEARING"/>
    </condition>
  </extension>

  <!-- IVR option 3: lower the actuator. Same busy/started handling as raise. -->
  <extension name="disco-lower">
    <condition field="destination_number" expression="^DISCO_LOWER$">
      <action application="set" data="disco_move=${system($${disco_lower})}"/>
      <action application="transfer" data="DISCO_LOWER_RESULT XML default"/>
    </condition>
  </extension>

  <extension name="disco-lower-result">
    <condition field="destination_number" expression="^DISCO_LOWER_RESULT$"/>
    <condition field="${disco_move}" expression="busy">
      <action application="playback" data="ivr/ivr-that_was_an_invalid_entry.wav"/>
      <action application="hangup" data="NORMAL_CLEARING"/>
      <anti-action application="playback" data="tone_stream://%(300,100,1100);%(300,100,900);%(300,100,700)"/>
      <anti-action application="hangup" data="NORMAL_CLEARING"/>
    </condition>
  </extension>

  <!-- IVR option 4: stop/brake. Cancels any movement in progress. -->
  <extension name="disco-stop">
    <condition field="destination_number" expression="^DISCO_STOP$">
      <action application="system" data="$${disco_stop}"/>
      <action application="playback" data="tone_stream://%(500,0,480,620)"/>
      <action application="hangup" data="NORMAL_CLEARING"/>
    </condition>
  </extension>
</include>
