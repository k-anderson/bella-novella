<include>
  <!-- ===================================================================
       Main menu (700). The ATA off-hook auto-dials 700; any other inbound
       call is routed here by 99_all_calls_to_ivr.xml.

       Options:
         1   = intercom the other phone
         2   = leave a message   (see 20_disco_messages.xml)
         3   = listen to messages (see 20_disco_messages.xml)
         911 = raise the disco ball
         411 = lower the disco ball
         #   = stop the disco ball
       Anything else plays a random "invalid" prompt. Every path returns here.
       =================================================================== -->
  <extension name="disco-menu">
    <condition field="destination_number" expression="^700$">
      <action application="answer"/>
      <action application="sleep" data="100"/>
      <action application="set" data="disco_opt="/>
      <!-- min=1 max=3, '*' terminator (so '#' stays a valid option), validate
           to the known options; 2s inter-digit timeout resolves 1 vs 911. -->
      <action application="play_and_get_digits"
              data="1 3 1 7000 * $${recordings_dir}/main-menu.wav silence_stream://100 disco_opt '^(1|2|3|911|411|#)$' 2000"/>
      <action application="transfer" data="DISCO_DISPATCH XML default"/>
    </condition>
  </extension>

  <!-- Dispatch runs in a fresh routing pass so ${disco_opt} is populated. Each
       option has its own extension; the final catch-all handles invalid/empty
       input. Whichever matches transfers away before the catch-all runs. -->
  <extension name="disco-dispatch-call">
    <condition field="destination_number" expression="^DISCO_DISPATCH$"/>
    <condition field="${disco_opt}" expression="^1$">
      <action application="transfer" data="DISCO_CALL_OTHER XML default"/>
    </condition>
  </extension>

  <extension name="disco-dispatch-leave">
    <condition field="destination_number" expression="^DISCO_DISPATCH$"/>
    <condition field="${disco_opt}" expression="^2$">
      <action application="transfer" data="DISCO_LEAVE XML default"/>
    </condition>
  </extension>

  <extension name="disco-dispatch-listen">
    <condition field="destination_number" expression="^DISCO_DISPATCH$"/>
    <condition field="${disco_opt}" expression="^3$">
      <action application="transfer" data="DISCO_LISTEN XML default"/>
    </condition>
  </extension>

  <extension name="disco-dispatch-raise">
    <condition field="destination_number" expression="^DISCO_DISPATCH$"/>
    <condition field="${disco_opt}" expression="^911$">
      <action application="transfer" data="DISCO_RAISE XML default"/>
    </condition>
  </extension>

  <extension name="disco-dispatch-lower">
    <condition field="destination_number" expression="^DISCO_DISPATCH$"/>
    <condition field="${disco_opt}" expression="^411$">
      <action application="transfer" data="DISCO_LOWER XML default"/>
    </condition>
  </extension>

  <extension name="disco-dispatch-stop">
    <condition field="destination_number" expression="^DISCO_DISPATCH$"/>
    <condition field="${disco_opt}" expression="^#$">
      <action application="transfer" data="DISCO_STOP XML default"/>
    </condition>
  </extension>

  <!-- Catch-all: invalid or no selection -> one of six random prompts -> menu. -->
  <extension name="disco-dispatch-invalid">
    <condition field="destination_number" expression="^DISCO_DISPATCH$">
      <action application="playback" data="${system($${disco_messages} invalid-prompt)}"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <!-- Option 1: intercom the other line, then return to the menu. -->
  <extension name="disco-call-other-from-101">
    <condition field="destination_number" expression="^DISCO_CALL_OTHER$"/>
    <condition field="${sip_from_user}" expression="^101$">
      <action application="set" data="hangup_after_bridge=false"/>
      <action application="set" data="continue_on_fail=true"/>
      <action application="set" data="effective_caller_id_number=101"/>
      <action application="set" data="effective_caller_id_name=Line 101"/>
      <action application="bridge" data="${sofia_contact(102@$${domain})}"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <extension name="disco-call-other-from-102">
    <condition field="destination_number" expression="^DISCO_CALL_OTHER$"/>
    <condition field="${sip_from_user}" expression="^102$">
      <action application="set" data="hangup_after_bridge=false"/>
      <action application="set" data="continue_on_fail=true"/>
      <action application="set" data="effective_caller_id_number=102"/>
      <action application="set" data="effective_caller_id_name=Line 102"/>
      <action application="bridge" data="${sofia_contact(101@$${domain})}"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <!-- Fallback if option 1 is selected from an unexpected SIP user. -->
  <extension name="disco-call-other-unknown-line">
    <condition field="destination_number" expression="^DISCO_CALL_OTHER$">
      <action application="playback" data="ivr/ivr-that_was_an_invalid_entry.wav"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <!-- 911: raise the disco ball, unless it is already up. Position comes from
       disco-relay (up / down / unknown); unknown at boot or after #. -->
  <extension name="disco-raise">
    <condition field="destination_number" expression="^DISCO_RAISE$">
      <action application="answer"/>
      <action application="set" data="disco_pos=${system($${disco_position})}"/>
      <action application="transfer" data="DISCO_RAISE_GO XML default"/>
    </condition>
  </extension>

  <extension name="disco-raise-go">
    <condition field="destination_number" expression="^DISCO_RAISE_GO$"/>
    <condition field="${disco_pos}" expression="^up$">
      <!-- already up: play the "already up" prompt, do not move -->
      <action application="playback" data="$${recordings_dir}/disco-already-up.wav"/>
      <action application="transfer" data="700 XML default"/>
      <!-- not up (down or unknown): announce and raise -->
      <anti-action application="playback" data="$${recordings_dir}/disco-raise.wav"/>
      <anti-action application="set" data="disco_move=${system($${disco_raise})}"/>
      <anti-action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <!-- 411: lower the disco ball, unless it is already down. -->
  <extension name="disco-lower">
    <condition field="destination_number" expression="^DISCO_LOWER$">
      <action application="answer"/>
      <action application="set" data="disco_pos=${system($${disco_position})}"/>
      <action application="transfer" data="DISCO_LOWER_GO XML default"/>
    </condition>
  </extension>

  <extension name="disco-lower-go">
    <condition field="destination_number" expression="^DISCO_LOWER_GO$"/>
    <condition field="${disco_pos}" expression="^down$">
      <!-- already down: play the "already down" prompt, do not move -->
      <action application="playback" data="$${recordings_dir}/disco-already-down.wav"/>
      <action application="transfer" data="700 XML default"/>
      <!-- not down (up or unknown): announce and lower -->
      <anti-action application="playback" data="$${recordings_dir}/disco-lower.wav"/>
      <anti-action application="set" data="disco_move=${system($${disco_lower})}"/>
      <anti-action application="transfer" data="700 XML default"/>
    </condition>
  </extension>

  <!-- #: stop the disco ball, cancelling any movement in progress. This also
       resets the tracked position to "unknown" so 911 or 411 work next. -->
  <extension name="disco-stop">
    <condition field="destination_number" expression="^DISCO_STOP$">
      <action application="answer"/>
      <action application="playback" data="ivr/ivr-recording_stopped.wav"/>
      <action application="set" data="disco_move=${system($${disco_stop})}"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>
</include>
