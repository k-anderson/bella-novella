<include>
  <!-- Option 1: intercom the other line, then return to the menu. Both lines
       ring the far phone by transferring to its explicit extension
       (00_extensions.xml), which sets the caller ID, handles ringback,
       no-answer, and returning to 700. -->
  <extension name="call-other-from-101">
    <condition field="destination_number" expression="^CALL_OTHER$"/>
    <condition field="${sip_from_user}" expression="^101$">
      <action application="transfer" data="102 XML default"/>
    </condition>
  </extension>

  <extension name="call-other-from-102">
    <condition field="destination_number" expression="^CALL_OTHER$"/>
    <condition field="${sip_from_user}" expression="^102$">
      <action application="transfer" data="101 XML default"/>
    </condition>
  </extension>

  <!-- Fallback if option 1 is selected from an unexpected SIP user. -->
  <extension name="call-other-unknown-line">
    <condition field="destination_number" expression="^CALL_OTHER$">
      <action application="playback" data="$${prompts_dir}/no-answer.wav"/>
      <action application="sleep" data="1500"/>
      <action application="transfer" data="700 XML default"/>
    </condition>
  </extension>
</include>
