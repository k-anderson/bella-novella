<configuration name="logfile.conf" description="File logger">
  <settings>
    <param name="rotate-on-hup" value="true"/>
  </settings>

  <profiles>
    <profile name="default">
      <settings>
        <param name="logfile" value="$${log_dir}/freeswitch.log"/>
        <param name="rollover" value="10485760"/>
        <param name="maximum-rotate" value="2"/>
        <param name="uuid" value="true"/>
      </settings>
      <mappings>
        <!-- Only warnings and above are written to the SD card, to minimize
             flash wear. Live info/debug is still available over fs_cli/ESL, or
             temporarily with `fs_cli -x "fsctl loglevel debug"`. -->
        <map name="all" value="warning,err,crit,alert"/>
      </mappings>
    </profile>
  </profiles>
</configuration>
