<include>
  <profile name="ata">
    <settings>
      <!-- Bind only to the isolated Ethernet ATA address. -->
      <param name="sip-ip" value="$${bind_server_ip}"/>
      <param name="rtp-ip" value="$${bind_server_ip}"/>
      <param name="ext-sip-ip" value="$${bind_server_ip}"/>
      <param name="ext-rtp-ip" value="$${bind_server_ip}"/>
      <param name="sip-port" value="5060"/>
      <param name="bind-params" value="transport=udp"/>
      <param name="tls-only" value="false"/>
      <param name="tls-sip-port" value="5061"/>
      <param name="ws-binding" value=""/>
      <param name="wss-binding" value=""/>

      <!-- Routing -->
      <param name="context" value="default"/>
      <param name="dialplan" value="XML"/>
      <param name="sip-domain" value="$${domain}"/>
      <param name="challenge-realm" value="auto_to"/>

      <!-- Isolated-network trust model -->
      <param name="auth-calls" value="false"/>
      <param name="auth-all-packets" value="false"/>
      <param name="auth-messages" value="false"/>
      <param name="accept-blind-auth" value="true"/>
      <param name="accept-blind-reg" value="true"/>
      <param name="disable-register" value="false"/>
      <param name="log-auth-failures" value="true"/>

      <!-- Defense in depth -->
      <param name="apply-inbound-acl" value="bella_ata_only"/>
      <param name="apply-register-acl" value="bella_ata_only"/>
      <param name="local-network-acl" value="bella_ata_only"/>

      <!-- Registration model -->
      <param name="force-register-domain" value="$${domain}"/>
      <param name="force-register-db-domain" value="$${domain}"/>
      <param name="multiple-registrations" value="false"/>
      <param name="max-registrations-per-extension" value="1"/>
      <param name="registration-thread-frequency" value="30"/>
      <param name="inbound-reg-force-matching-username" value="false"/>
      <param name="inbound-reg-in-new-thread" value="false"/>
      <param name="send-message-query-on-register" value="false"/>
      <param name="send-presence-on-register" value="false"/>
      <param name="presence-probe-on-register" value="false"/>
      <param name="all-reg-options-ping" value="false"/>
      <param name="nat-options-ping" value="false"/>
      <param name="unregister-on-options-fail" value="false"/>

      <!-- POTS/ATA media -->
      <param name="inbound-codec-prefs" value="$${global_codec_prefs}"/>
      <param name="outbound-codec-prefs" value="$${outbound_codec_prefs}"/>
      <param name="codec-prefs" value="$${global_codec_prefs}"/>
      <param name="inbound-codec-negotiation" value="scrooge"/>
      <param name="inbound-late-negotiation" value="false"/>
      <param name="disable-transcoding" value="false"/>
      <param name="dtmf-type" value="rfc2833"/>
      <param name="rfc2833-pt" value="101"/>
      <param name="dtmf-duration" value="2000"/>
      <param name="pass-rfc2833" value="true"/>
      <param name="liberal-dtmf" value="true"/>
      <param name="suppress-cng" value="true"/>
      <param name="cng-pt" value="13"/>
      <param name="vad" value="none"/>
      <param name="hold-music" value="$${hold_music}"/>
      <param name="disable-hold" value="false"/>
      <param name="renegotiate-codec-on-hold" value="false"/>
      <param name="renegotiate-codec-on-reinvite" value="false"/>
      <param name="inbound-bypass-media" value="false"/>
      <param name="inbound-proxy-media" value="false"/>
      <param name="inbound-no-media" value="false"/>
      <param name="require-secure-rtp" value="false"/>
      <param name="t38-passthru" value="false"/>

      <!-- RTP timing/liveness -->
      <param name="rtp-timer-name" value="timerfd"/>
      <param name="rtp-autofix-timing" value="false"/>
      <param name="rtp-rewrite-timestamps" value="false"/>
      <param name="rtp-notimer-during-bridge" value="false"/>
      <param name="rtp-timeout-sec" value="60"/>
      <param name="rtp-hold-timeout-sec" value="300"/>
      <param name="rtcp-audio-interval-msec" value="5000"/>
      <param name="rtp-digit-delay" value="40"/>
      <param name="disable-rtp-auto-adjust" value="false"/>

      <!-- SIP timers/options -->
      <param name="enable-timer" value="false"/>
      <param name="minimum-session-expires" value="120"/>
      <param name="session-timeout" value="0"/>
      <param name="timer-T1" value="500"/>
      <param name="timer-T1X64" value="32000"/>
      <param name="timer-T2" value="4000"/>
      <param name="timer-T4" value="4000"/>
      <param name="sip-expires-max-deviation" value="600"/>
      <param name="sip-expires-late-margin" value="60"/>
      <param name="sip-force-expires" value="0"/>
      <param name="sip-options-respond-503-on-busy" value="false"/>
      <param name="sip-messages-respond-200-ok" value="false"/>

      <!-- No NAT or external DNS behavior -->
      <param name="aggressive-nat-detection" value="false"/>
      <param name="disable-srv" value="true"/>
      <param name="disable-naptr" value="true"/>
      <param name="disable-srv503" value="true"/>
      <param name="NDLB-force-rport" value="safe"/>
      <param name="NDLB-received-in-nat-reg-contact" value="false"/>
      <param name="NDLB-expires-in-register-response" value="false"/>

      <!-- Disable nonessential presence/message behaviors -->
      <param name="manage-presence" value="false"/>
      <param name="manage-shared-appearance" value="false"/>
      <param name="presence-disable-early" value="true"/>
      <param name="presence-privacy" value="true"/>
      <param name="fire-message-events" value="false"/>
      <param name="in-dialog-chat" value="false"/>
      <param name="forward-unsolicited-mwi-notify" value="false"/>
      <param name="mwi-use-reg-callid" value="false"/>

      <!-- Diagnostics -->
      <param name="sip-trace" value="false"/>
      <param name="tracelevel" value="0"/>
      <param name="log-level" value="0"/>
      <param name="debug-presence" value="0"/>
      <param name="debug-sla" value="0"/>
      <param name="parse-all-invite-headers" value="false"/>
      <param name="extended-info-parsing" value="false"/>
      <param name="track-calls" value="false"/>
      <param name="user-agent-string" value="Bella-FreeSWITCH"/>
      <param name="dbname" value="sofia_reg_ata"/>
      <param name="shutdown-on-fail" value="true"/>
      <param name="profile-standby" value="false"/>
      <param name="auto-restart" value="true"/>
    </settings>

    <gateways>
      <!-- No gateways. -->
    </gateways>

    <aliases>
      <!-- No aliases. -->
    </aliases>
  </profile>
</include>
